meta {
  name: Update Valoracion No Existe
  type: http
  seq: 11
}

put {
  url: {{baseUrl}}/Valoraciones/99999
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "productoId": 1,
    "estrellas": 3,
    "resena": "Esta valoracion no existe"
  }
}

assert {
  res.status: eq 404
  res.body.message: isString
}
