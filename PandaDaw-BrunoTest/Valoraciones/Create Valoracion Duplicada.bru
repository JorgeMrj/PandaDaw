meta {
  name: Create Valoracion Duplicada
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/Valoraciones
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "productoId": 1,
    "estrellas": 4,
    "resena": "Intentando valorar de nuevo el mismo producto"
  }
}

assert {
  res.status: eq 409
  res.body.message: isString
}
