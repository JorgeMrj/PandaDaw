meta {
  name: Get Venta By Id
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/Ventas/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.id: eq 1
  res.body.fechaCompra: isString
  res.body.total: isNumber
  res.body.estado: isString
  res.body.lineas: isArray
}
