meta {
  name: Add Linea Carrito
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/Carrito/lineas
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "productoId": 1,
    "cantidad": 2
  }
}

assert {
  res.status: eq 200
  res.body.id: isNumber
  res.body.lineas: isArray
  res.body.total: isNumber
  res.body.totalItems: isNumber
}
