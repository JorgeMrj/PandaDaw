meta {
  name: Update Linea Carrito
  type: http
  seq: 7
}

put {
  url: {{baseUrl}}/Carrito/lineas/1
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "cantidad": 5
  }
}

assert {
  res.status: eq 200
  res.body.id: isNumber
  res.body.lineas: isArray
  res.body.total: isNumber
}
