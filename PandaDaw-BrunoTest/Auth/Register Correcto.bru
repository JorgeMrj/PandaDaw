meta {
  name: Register Correcto
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/Auth/register
  body: json
  auth: none
}

body:json {
  {
    "nombre": "Test",
    "apellidos": "Usuario Bruno",
    "email": "brunotest@test.com",
    "password": "Test123!"
  }
}

assert {
  res.status: eq 201
  res.body.nombre: eq Test
  res.body.apellidos: eq Usuario Bruno
  res.body.email: eq brunotest@test.com
  res.body.role: eq User
}
