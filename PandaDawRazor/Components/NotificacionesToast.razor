@using PandaDawRazor.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject NotificacionService NotificacionService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="fixed top-16 sm:top-20 right-2 sm:right-4 z-[99999] flex flex-col gap-2 pointer-events-none max-w-xs sm:max-w-sm w-full"
     style="max-height: calc(100vh - 80px); overflow-y: auto;">
    @foreach (var notif in notificaciones.ToList())
    {
        <div class="pointer-events-auto transform transition-all duration-300 ease-out"
             style="animation: toastSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);">
            <div class="rounded-xl shadow-2xl bg-base-100 border-l-4 p-3 flex items-start gap-3 relative
                        @GetBorderColor(notif.Tipo)">
                
                <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 @GetIconBgClass(notif.Tipo)">
                    <i class="@notif.Icono text-sm @GetIconColorClass(notif.Tipo)"></i>
                </div>

                <div class="flex-1 min-w-0">
                    <p class="font-bold text-xs sm:text-sm truncate">@notif.Titulo</p>
                    <p class="text-xs mt-0.5 opacity-70 line-clamp-2">@notif.Mensaje</p>
                </div>

                <button class="btn btn-ghost btn-xs btn-circle opacity-50 hover:opacity-100 shrink-0"
                        @onclick="() => CerrarNotificacion(notif)">
                    <i class="fa-solid fa-xmark text-xs"></i>
                </button>
                
                <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-base-300/20">
                    <div class="h-full @GetProgressBarColor(notif.Tipo)" style="animation: shrink-width 4s linear forwards;"></div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    @@keyframes toastSlideIn {
        from { opacity: 0; transform: translateX(100%); }
        to { opacity: 1; transform: translateX(0); }
    }
    @@keyframes shrink-width {
        from { width: 100%; }
        to { width: 0%; }
    }
</style>

<style>
    @@keyframes toastSlideIn {
        from { opacity: 0; transform: translateX(100%); }
        to { opacity: 1; transform: translateX(0); }
    }
    @@keyframes shrink-width {
        from { width: 100%; }
        to { width: 0%; }
    }
</style>

@code {
    [Parameter] public string? UserId { get; set; }

    private List<Notificacion> notificaciones = new();
    private readonly int DuracionNotificacion = 4000;
    private readonly Dictionary<string, CancellationTokenSource> _timerCts = new();
    private readonly object _lock = new();

    protected override void OnInitialized()
    {
        NotificacionService.OnNotificacion += HandleNotificacion;
    }

    private Task HandleNotificacionAsync(string targetUserId, Notificacion notif)
    {
        if (!string.IsNullOrEmpty(targetUserId) && targetUserId != UserId) 
            return Task.CompletedTask;

        return InvokeAsync(() =>
        {
            notif.Fecha = DateTime.Now;
            notificaciones.Add(notif);
            StateHasChanged();
            
            StartAutoClose(notif);
        });
    }

    private void HandleNotificacion(string targetUserId, Notificacion notif)
    {
        _ = HandleNotificacionAsync(targetUserId, notif);
    }

    private void StartAutoClose(Notificacion notif)
    {
        lock (_lock)
        {
            if (_timerCts.ContainsKey(notif.Id))
            {
                try { _timerCts[notif.Id].Cancel(); _timerCts[notif.Id].Dispose(); } 
                catch { }
            }
            
            var cts = new CancellationTokenSource();
            _timerCts[notif.Id] = cts;
            var token = cts.Token;

            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(DuracionNotificacion, token);
                    if (!token.IsCancellationRequested)
                    {
                        await InvokeAsync(() =>
                        {
                            if (notificaciones.Contains(notif))
                            {
                                CerrarNotificacion(notif);
                            }
                        });
                    }
                }
                catch (TaskCanceledException) { }
                finally
                {
                    lock (_lock)
                    {
                        if (_timerCts.TryGetValue(notif.Id, out var removedCts) && removedCts == cts)
                        {
                            _timerCts.Remove(notif.Id);
                            try { cts.Dispose(); } catch { }
                        }
                    }
                }
            }, token);
        }
    }

    private void CerrarNotificacion(Notificacion notif)
    {
        lock (_lock)
        {
            if (_timerCts.TryGetValue(notif.Id, out var cts))
            {
                try { cts.Cancel(); cts.Dispose(); } catch { }
                _timerCts.Remove(notif.Id);
            }
        }
        
        notificaciones.Remove(notif);
        StateHasChanged();
    }

    private string GetBorderColor(string tipo) => tipo switch
    {
        "success" => "border-success",
        "warning" => "border-warning", 
        "error"   => "border-error",
        "info"    => "border-info",
        _         => "border-primary"
    };

    private string GetIconBgClass(string tipo) => tipo switch
    {
        "success" => "bg-success/10",
        "warning" => "bg-warning/10",
        "error"   => "bg-error/10",
        "info"    => "bg-info/10",
        _         => "bg-primary/10"
    };

    private string GetIconColorClass(string tipo) => tipo switch
    {
        "success" => "text-success",
        "warning" => "text-warning",
        "error"   => "text-error",
        "info"    => "text-info",
        _         => "text-primary"
    };

    private string GetProgressBarColor(string tipo) => tipo switch
    {
        "success" => "bg-success",
        "warning" => "bg-warning",
        "error"   => "bg-error",
        "info"    => "bg-info",
        _         => "bg-primary"
    };

    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        NotificacionService.OnNotificacion += HandleNotificacion;
        await InitSignalR();
    }

    private async Task InitSignalR()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/notificacionhub"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<Notificacion>("NotificacionRecibida", (notif) =>
            {
                Console.WriteLine($"SignalR received notification: {notif.Titulo}");
                if (string.IsNullOrEmpty(UserId) || notif.Tipo == "broadcast")
                {
                    InvokeAsync(() =>
                    {
                        notif.Fecha = DateTime.Now;
                        notificaciones.Add(notif);
                        StateHasChanged();
                        StartAutoClose(notif);
                    });
                }
            });

            await _hubConnection.StartAsync();
            if (!string.IsNullOrEmpty(UserId))
            {
                await _hubConnection.InvokeAsync("JoinGroup", UserId);
            }
            Console.WriteLine($"SignalR connected for user: {UserId}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignalR connection error: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        NotificacionService.OnNotificacion -= HandleNotificacion;
        
        lock (_lock)
        {
            foreach (var cts in _timerCts.Values)
            {
                try { cts.Cancel(); cts.Dispose(); } catch { }
            }
            _timerCts.Clear();
        }

        if (_hubConnection != null)
        {
            try
            {
                await _hubConnection.StopAsync();
                await _hubConnection.DisposeAsync();
            }
            catch { }
        }
    }
}
