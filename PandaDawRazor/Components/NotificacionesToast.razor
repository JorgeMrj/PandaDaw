@using PandaDawRazor.Services
@inject NotificacionService NotificacionService
@implements IDisposable

<div class="fixed top-4 right-4 z-[9999] flex flex-col gap-3 pointer-events-none max-w-sm w-full">
    @foreach (var notif in notificaciones.ToList())
    {
        <div class="pointer-events-auto transform transition-all duration-300 ease-out"
             style="animation: toastSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)">
            <div class="rounded-2xl shadow-2xl border-2 p-4 flex items-start gap-3 overflow-hidden relative
                        @GetContainerClass(notif.Tipo)">
                <div class="absolute left-0 top-0 bottom-0 w-1.5 rounded-l-xl @GetBarColor(notif.Tipo)"></div>
                
                <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0 @GetIconBgClass(notif.Tipo)">
                    <i class="@notif.Icono @GetIconColorClass(notif.Tipo)"></i>
                </div>

                <div class="flex-1 min-w-0">
                    <p class="font-bold text-sm">@notif.Titulo</p>
                    <p class="text-xs mt-0.5 opacity-80">@notif.Mensaje</p>
                    <p class="text-[10px] opacity-50 mt-1">@notif.Fecha.ToString("HH:mm")</p>
                </div>

                <button class="btn btn-ghost btn-xs btn-circle opacity-50 hover:opacity-100 shrink-0"
                        @onclick="() => CerrarNotificacion(notif)">
                    <i class="fa-solid fa-xmark"></i>
                </button>
                
                <div class="absolute bottom-0 left-0 right-0 h-1 bg-base-300/30">
                    <div class="h-full @GetProgressBarColor(notif.Tipo)" style="animation: shrink-width 4s linear forwards;"></div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    @@keyframes toastSlideIn {
        from { opacity: 0; transform: translateX(120%); }
        to { opacity: 1; transform: translateX(0); }
    }
    @@keyframes shrink-width {
        from { width: 100%; }
        to { width: 0%; }
    }
</style>

@code {
    [Parameter] public string? UserId { get; set; }

    private List<Notificacion> notificaciones = new();
    private readonly int DuracionNotificacion = 4000;
    private readonly Dictionary<string, CancellationTokenSource> _timerCts = new();
    private readonly object _lock = new();

    protected override void OnInitialized()
    {
        NotificacionService.OnNotificacion += HandleNotificacion;
    }

    private Task HandleNotificacionAsync(string targetUserId, Notificacion notif)
    {
        if (!string.IsNullOrEmpty(targetUserId) && targetUserId != UserId) 
            return Task.CompletedTask;

        return InvokeAsync(() =>
        {
            notif.Fecha = DateTime.Now;
            notificaciones.Add(notif);
            StateHasChanged();
            
            StartAutoClose(notif);
        });
    }

    private void HandleNotificacion(string targetUserId, Notificacion notif)
    {
        _ = HandleNotificacionAsync(targetUserId, notif);
    }

    private void StartAutoClose(Notificacion notif)
    {
        lock (_lock)
        {
            if (_timerCts.ContainsKey(notif.Id))
            {
                try { _timerCts[notif.Id].Cancel(); _timerCts[notif.Id].Dispose(); } 
                catch { }
            }
            
            var cts = new CancellationTokenSource();
            _timerCts[notif.Id] = cts;
            var token = cts.Token;

            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(DuracionNotificacion, token);
                    if (!token.IsCancellationRequested)
                    {
                        await InvokeAsync(() =>
                        {
                            if (notificaciones.Contains(notif))
                            {
                                CerrarNotificacion(notif);
                            }
                        });
                    }
                }
                catch (TaskCanceledException) { }
                finally
                {
                    lock (_lock)
                    {
                        if (_timerCts.TryGetValue(notif.Id, out var removedCts) && removedCts == cts)
                        {
                            _timerCts.Remove(notif.Id);
                            try { cts.Dispose(); } catch { }
                        }
                    }
                }
            }, token);
        }
    }

    private void CerrarNotificacion(Notificacion notif)
    {
        lock (_lock)
        {
            if (_timerCts.TryGetValue(notif.Id, out var cts))
            {
                try { cts.Cancel(); cts.Dispose(); } catch { }
                _timerCts.Remove(notif.Id);
            }
        }
        
        notificaciones.Remove(notif);
        StateHasChanged();
    }

    private string GetContainerClass(string tipo) => tipo switch
    {
        "success" => "bg-white border-success",
        "warning" => "bg-white border-warning", 
        "error"   => "bg-white border-error",
        "info"    => "bg-white border-info",
        _         => "bg-white border-primary"
    };

    private string GetBarColor(string tipo) => tipo switch
    {
        "success" => "bg-success",
        "warning" => "bg-warning",
        "error"   => "bg-error",
        "info"    => "bg-info",
        _         => "bg-primary"
    };

    private string GetIconBgClass(string tipo) => tipo switch
    {
        "success" => "bg-success/10",
        "warning" => "bg-warning/10",
        "error"   => "bg-error/10",
        "info"    => "bg-info/10",
        _         => "bg-primary/10"
    };

    private string GetIconColorClass(string tipo) => tipo switch
    {
        "success" => "text-success",
        "warning" => "text-warning",
        "error"   => "text-error",
        "info"    => "text-info",
        _         => "text-primary"
    };

    private string GetProgressBarColor(string tipo) => tipo switch
    {
        "success" => "bg-success",
        "warning" => "bg-warning",
        "error"   => "bg-error",
        "info"    => "bg-info",
        _         => "bg-primary"
    };

    public void Dispose()
    {
        NotificacionService.OnNotificacion -= HandleNotificacion;
        
        lock (_lock)
        {
            foreach (var cts in _timerCts.Values)
            {
                try { cts.Cancel(); cts.Dispose(); } catch { }
            }
            _timerCts.Clear();
        }
    }
}
