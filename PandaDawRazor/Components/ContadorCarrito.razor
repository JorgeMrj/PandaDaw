@using PandaDawRazor.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject NotificacionService NotificacionService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<span class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-primary text-[10px] font-black text-primary-content flex items-center justify-center shadow-lg @(animating ? "scale-125" : "")"
      style="transition: transform 0.3s cubic-bezier(0.22,0.61,0.36,1)"
      id="cart-badge-blazor">
    @(count > 99 ? "99+" : count)
</span>

@code {
    [Parameter] public string? UserId { get; set; }
    [Parameter] public int InitialCount { get; set; }

    private int count;
    private bool animating;
    private CancellationTokenSource? _animationCts;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        count = Math.Max(0, InitialCount);
        NotificacionService.OnCarritoActualizado += HandleCarritoActualizado;
        await InitSignalR();
    }

    private async Task InitSignalR()
    {
        if (string.IsNullOrEmpty(UserId)) return;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/notificacionhub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<string, int>("CarritoActualizado", (userId, totalItems) =>
        {
            if (userId == UserId)
            {
                InvokeAsync(() =>
                {
                    count = Math.Max(0, totalItems);
                    animating = true;
                    StateHasChanged();

                    _ = Task.Run(async () =>
                    {
                        await Task.Delay(300);
                        await InvokeAsync(() =>
                        {
                            animating = false;
                            StateHasChanged();
                        });
                    });
                });
            }
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinGroup", UserId);
        }
        catch { }
    }

    protected override void OnParametersSet()
    {
        if (InitialCount >= 0 && count != InitialCount)
        {
            count = InitialCount;
        }
    }

    private Task HandleCarritoActualizadoAsync(string targetUserId, int totalItems)
    {
        return InvokeAsync(async () =>
        {
            try
            {
                _animationCts?.Cancel();
                _animationCts?.Dispose();
            }
            catch { }

            _animationCts = new CancellationTokenSource();
            var token = _animationCts.Token;

            count = Math.Max(0, totalItems);
            animating = true;
            StateHasChanged();

            try
            {
                await Task.Delay(300, token);
                if (!token.IsCancellationRequested)
                {
                    animating = false;
                    StateHasChanged();
                }
            }
            catch (TaskCanceledException)
            {
            }
        });
    }

    private void HandleCarritoActualizado(string targetUserId, int totalItems)
    {
        _ = HandleCarritoActualizadoAsync(targetUserId, totalItems);
    }

    public async ValueTask DisposeAsync()
    {
        NotificacionService.OnCarritoActualizado -= HandleCarritoActualizado;
        
        try
        {
            _animationCts?.Cancel();
            _animationCts?.Dispose();
        }
        catch { }

        if (_hubConnection != null)
        {
            try
            {
                await _hubConnection.StopAsync();
                await _hubConnection.DisposeAsync();
            }
            catch { }
        }
    }
}
