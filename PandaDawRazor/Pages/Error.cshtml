@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="min-h-[calc(100vh-120px)] flex items-center justify-center p-6 relative overflow-hidden">
    <!-- Decorative background -->
    <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-error/3 rounded-full blur-3xl"></div>
        <div class="absolute bottom-1/4 right-1/4 w-72 h-72 bg-primary/3 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 text-center max-w-md w-full space-y-8">
        <!-- Animated error icon -->
        <div class="relative mx-auto w-28 h-28">
            <div class="absolute inset-0 bg-error/5 rounded-full animate-ping"></div>
            <div class="relative w-28 h-28 rounded-full bg-error/8 border border-error/10 flex items-center justify-center">
                <i class="fa-solid fa-triangle-exclamation text-5xl text-error/80"></i>
            </div>
        </div>

        <!-- Error text -->
        <div class="space-y-3">
            <h1 class="text-3xl font-extrabold text-base-content tracking-tight">Algo salió mal</h1>
            <p class="text-base-content/40 text-sm font-medium leading-relaxed max-w-xs mx-auto">
                Se ha producido un error inesperado al procesar tu solicitud.
            </p>
        </div>

        <!-- Request ID -->
        @if (Model.ShowRequestId)
        {
            <div class="bg-base-300/5 border border-base-300/8 rounded-2xl px-5 py-4 text-left">
                <div class="flex items-center gap-2 mb-1.5">
                    <i class="fa-solid fa-fingerprint text-[10px] text-base-content/30"></i>
                    <p class="text-[10px] font-bold uppercase tracking-wider text-base-content/30">Request ID</p>
                </div>
                <p class="font-mono text-xs text-base-content/50 break-all">@Model.RequestId</p>
            </div>
        }

        <!-- Action buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a asp-page="/Index" class="btn btn-primary rounded-2xl font-bold gap-2 shadow-md px-8">
                <i class="fa-solid fa-home text-xs"></i>
                Volver al inicio
            </a>
            <button onclick="location.reload()" class="btn btn-ghost rounded-2xl font-semibold gap-2 text-base-content/40 hover:text-base-content/60">
                <i class="fa-solid fa-rotate-right text-xs"></i>
                Reintentar
            </button>
        </div>
    </div>
</div>
