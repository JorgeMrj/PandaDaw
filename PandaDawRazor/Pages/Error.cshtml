@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="min-h-[calc(100vh-200px)] flex items-center justify-center p-6">
    <div class="card bg-white shadow-md border-0 rounded-3xl max-w-lg w-full">
        <div class="card-body items-center text-center gap-5 p-10">
            <div class="w-24 h-24 rounded-3xl bg-error/8 flex items-center justify-center">
                <i class="fa-solid fa-triangle-exclamation text-4xl text-error"></i>
            </div>
            <h1 class="text-2xl font-extrabold text-base-content tracking-tight">Ha ocurrido un error</h1>
            <p class="text-base-content/40 text-sm font-medium">Se ha producido un error al procesar tu solicitud.</p>

            @if (Model.ShowRequestId)
            {
                <div class="bg-base-200/40 rounded-2xl px-5 py-3.5 w-full">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-base-content/40">Request ID</p>
                    <p class="font-mono text-sm text-base-content/60 mt-0.5">@Model.RequestId</p>
                </div>
            }

            <a asp-page="/Index" class="btn btn-primary rounded-2xl font-bold mt-3 gap-2 shadow-md">
                <i class="fa-solid fa-home text-xs"></i>
                Volver al inicio
            </a>
        </div>
    </div>
</div>