@page
@model PandaDawRazor.Pages.LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "_Layout";
}

<div class="min-h-[calc(100vh-200px)] flex items-center justify-center p-6 relative">
    <!-- Decoración de fondo -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-primary/3 blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full bg-secondary/3 blur-3xl"></div>
    </div>
    
    <div class="card w-full max-w-md bg-white shadow-xl border-0 rounded-3xl relative z-10">
        <div class="card-body gap-7 p-9">
            <div class="flex flex-col items-center gap-4 text-center">
                <div class="w-16 h-16 rounded-3xl bg-gradient-to-br from-primary via-primary to-secondary flex items-center justify-center shadow-xl">
                    <i class="fa-solid fa-paw text-2xl text-white"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-extrabold text-base-content tracking-tight">Bienvenido de nuevo</h1>
                    <p class="text-sm text-base-content/45 mt-1">Inicia sesión para continuar</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-error shadow-lg rounded-2xl">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <form method="post" class="flex flex-col gap-5">
                @Html.AntiForgeryToken()

                <div class="form-control gap-2">
                    <label class="label py-0" for="loginEmail">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Correo electrónico</span>
                    </label>
                    <label class="input input-bordered flex items-center gap-3 focus-within:input-primary rounded-2xl h-12 bg-base-200/30">
                        <i class="fa-solid fa-envelope text-base-content/30 text-sm"></i>
                        <input asp-for="Input.Email" id="loginEmail" type="email" class="grow text-sm"
                               placeholder="tu@correo.com" autocomplete="email" required autofocus />
                    </label>
                    <span asp-validation-for="Input.Email" class="text-error text-xs"></span>
                </div>

                <div class="form-control gap-2">
                    <label class="label py-0" for="loginPassword">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Contraseña</span>
                    </label>
                    <label class="input input-bordered flex items-center gap-3 focus-within:input-primary rounded-2xl h-12 bg-base-200/30">
                        <i class="fa-solid fa-lock text-base-content/30 text-sm"></i>
                        <input asp-for="Input.Password" id="loginPassword" type="password" class="grow text-sm"
                               placeholder="••••••••" autocomplete="current-password" required />
                        <button type="button" onclick="togglePassword('loginPassword', 'eyeIconLogin')"
                                class="btn btn-ghost btn-xs btn-circle text-base-content/30 hover:text-base-content"
                                tabindex="-1" aria-label="Mostrar/ocultar contraseña">
                            <i id="eyeIconLogin" class="fa-solid fa-eye text-xs"></i>
                        </button>
                    </label>
                    <span asp-validation-for="Input.Password" class="text-error text-xs"></span>
                </div>

                <button type="submit" class="btn btn-primary w-full mt-1 rounded-2xl font-bold h-12 text-sm">
                    Iniciar sesión
                    <i class="fa-solid fa-arrow-right ml-1 text-xs"></i>
                </button>
            </form>

            <div class="divider text-base-content/25 text-xs font-medium my-0">o</div>

            <p class="text-center text-sm text-base-content/45">
                ¿No tienes cuenta?
                <a asp-page="/Register" class="link link-primary font-bold no-underline hover:underline">Regístrate gratis</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
    </script>
}