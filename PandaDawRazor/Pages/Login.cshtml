@page
@model PandaDawRazor.Pages.LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "_Layout";
}

<div class="bg-base-200 min-h-screen">
    <div class="min-h-screen flex items-center justify-center p-4">
        <!-- Card Login -->
        <div id="cardLogin" class="card w-full max-w-md bg-base-100 shadow-xl">
            <div class="card-body gap-6">
                <div class="flex flex-col items-center gap-2 text-center">
                    <h1 class="text-3xl font-bold text-base-content">PandaDaw</h1>
                    <p class="text-sm text-base-content/60">Bienvenido de nuevo</p>
                </div>

                <form method="post" action="/Account/Login" class="flex flex-col gap-4">
                    <!-- Email -->
                    <div class="form-control gap-1">
                        <label class="label py-0" for="email">
                            <span class="label-text font-medium">Correo electrónico</span>
                        </label>
                        <label class="input input-bordered flex items-center gap-2">
                            <i class="fa-solid fa-envelope text-base-content/40 text-sm"></i>
                            <input id="email" type="email" name="email" class="grow" placeholder="tu@correo.com" required autocomplete="email" />
                        </label>
                    </div>

                    <!-- Contraseña -->
                    <div class="form-control gap-1">
                        <label class="label py-0" for="password">
                            <span class="label-text font-medium">Contraseña</span>
                        </label>
                        <label class="input input-bordered flex items-center gap-2">
                            <i class="fa-solid fa-lock text-base-content/40 text-sm"></i>
                            <input id="password" type="password" name="password" class="grow" placeholder="••••••••" required autocomplete="current-password" />
                            <button type="button" onclick="togglePassword('password', 'eyeIconLogin')"
                                class="btn btn-ghost btn-xs px-1 text-base-content/40 hover:text-base-content"
                                tabindex="-1" aria-label="Mostrar/ocultar contraseña">
                                <i id="eyeIconLogin" class="fa-solid fa-eye"></i>
                            </button>
                        </label>
                    </div>

                    <!-- Recuérdame + Olvidé contraseña -->
                    <div class="flex items-center justify-between">
                        <label class="label cursor-pointer gap-2">
                            <input type="checkbox" name="rememberMe" class="checkbox checkbox-primary checkbox-sm" />
                            <span class="label-text text-sm">Recuérdame</span>
                        </label>
                        <a href="/Account/ForgotPassword" class="link link-primary text-sm">
                            ¿Olvidaste tu contraseña?
                        </a>
                    </div>

                    <button type="submit" class="btn btn-primary w-full mt-2">
                        <i class="fa-solid fa-right-to-bracket mr-1"></i>
                        Iniciar sesión
                    </button>
                </form>

                <p class="text-center text-sm text-base-content/60">
                    ¿No tienes cuenta?
                    <button onclick="switchCard('registro')" class="link link-primary font-medium">
                        Regístrate
                    </button>
                </p>
            </div>
        </div>

        <!-- Card Registro -->
        <div id="cardRegistro" class="card w-full max-w-md bg-base-100 shadow-xl hidden">
            <div class="card-body gap-6">
                <div class="flex flex-col items-center gap-2 text-center">
                    <h1 class="text-3xl font-bold text-base-content">PandaDaw</h1>
                    <p class="text-sm text-base-content/60">Crea tu cuenta</p>
                </div>

                <form method="post" action="/Account/Register" class="flex flex-col gap-4">
                    <!-- Nombre -->
                    <div class="form-control gap-1">
                        <label class="label py-0" for="regNombre">
                            <span class="label-text font-medium">Nombre</span>
                        </label>
                        <label class="input input-bordered flex items-center gap-2">
                            <i class="fa-solid fa-user text-base-content/40 text-sm"></i>
                            <input id="regNombre" type="text" name="nombre" class="grow" placeholder="Tu nombre" required autocomplete="name" />
                        </label>
                    </div>

                    <!-- Email -->
                    <div class="form-control gap-1">
                        <label class="label py-0" for="regEmail">
                            <span class="label-text font-medium">Correo electrónico</span>
                        </label>
                        <label class="input input-bordered flex items-center gap-2">
                            <i class="fa-solid fa-envelope text-base-content/40 text-sm"></i>
                            <input id="regEmail" type="email" name="email" class="grow" placeholder="tu@correo.com" required autocomplete="email" />
                        </label>
                    </div>

                    <!-- Contraseña -->
                    <div class="form-control gap-1">
                        <label class="label py-0" for="regPassword">
                            <span class="label-text font-medium">Contraseña</span>
                        </label>
                        <label class="input input-bordered flex items-center gap-2">
                            <i class="fa-solid fa-lock text-base-content/40 text-sm"></i>
                            <input id="regPassword" type="password" name="password" class="grow" placeholder="••••••••" required autocomplete="new-password" />
                            <button type="button" onclick="togglePassword('regPassword', 'eyeIconReg')"
                                class="btn btn-ghost btn-xs px-1 text-base-content/40 hover:text-base-content"
                                tabindex="-1" aria-label="Mostrar/ocultar contraseña">
                                <i id="eyeIconReg" class="fa-solid fa-eye"></i>
                            </button>
                        </label>
                    </div>

                    <!-- Confirmar contraseña -->
                    <div class="form-control gap-1">
                        <label class="label py-0" for="regConfirm">
                            <span class="label-text font-medium">Confirmar contraseña</span>
                        </label>
                        <label class="input input-bordered flex items-center gap-2">
                            <i class="fa-solid fa-lock text-base-content/40 text-sm"></i>
                            <input id="regConfirm" type="password" name="confirmPassword" class="grow" placeholder="••••••••" required autocomplete="new-password" />
                            <button type="button" onclick="togglePassword('regConfirm', 'eyeIconConfirm')"
                                class="btn btn-ghost btn-xs px-1 text-base-content/40 hover:text-base-content"
                                tabindex="-1" aria-label="Mostrar/ocultar contraseña">
                                <i id="eyeIconConfirm" class="fa-solid fa-eye"></i>
                            </button>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary w-full mt-2">
                        <i class="fa-solid fa-user-plus mr-1"></i>
                        Crear cuenta
                    </button>
                </form>

                <p class="text-center text-sm text-base-content/60">
                    ¿Ya tienes cuenta?
                    <button onclick="switchCard('login')" class="link link-primary font-medium">
                        Inicia sesión
                    </button>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function switchCard(to) {
            const login = document.getElementById("cardLogin");
            const registro = document.getElementById("cardRegistro");
            if (to === "registro") {
                login.classList.add("hidden");
                registro.classList.remove("hidden");
            } else {
                registro.classList.add("hidden");
                login.classList.remove("hidden");
            }
        }

        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
    </script>
}

