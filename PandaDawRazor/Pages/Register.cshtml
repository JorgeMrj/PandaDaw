@page
@model PandaDawRazor.Pages.RegisterModel
@{
    ViewData["Title"] = "Crear cuenta";
    Layout = "_Layout";
}

<div class="min-h-[calc(100vh-120px)] flex">
    <!-- Panel izquierdo: formulario -->
    <div class="flex-1 flex items-center justify-center p-6 sm:p-10">
        <div class="w-full max-w-md">
            <!-- Logo móvil -->
            <div class="lg:hidden flex items-center gap-2.5 mb-8">
                <span class="w-9 h-9 rounded-xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-glow">
                    <i class="fa-solid fa-paw text-base-100 text-sm"></i>
                </span>
                <span class="text-lg font-black tracking-tight text-gradient-emerald">PandaDaw</span>
            </div>

            <div class="mb-8">
                <h1 class="text-2xl sm:text-3xl font-black tracking-tight text-base-content mb-2">Crea tu cuenta</h1>
                <p class="text-sm text-base-content/30 font-medium">Únete a PandaDaw y accede a los mejores productos</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-error shadow-lg rounded-xl mb-6">
                    <i class="fa-solid fa-circle-exclamation text-sm"></i>
                    <span class="text-sm">@Model.ErrorMessage</span>
                </div>
            }

            <form method="post" class="flex flex-col gap-4">
                @Html.AntiForgeryToken()

                <div class="grid grid-cols-2 gap-3">
                    <div class="form-control gap-1.5">
                        <label class="text-[11px] font-bold uppercase tracking-widest text-base-content/35" for="regNombre">Nombre</label>
                        <input asp-for="Input.Nombre" id="regNombre" type="text"
                               class="input input-bordered rounded-xl h-11 text-sm border-base-300/15" placeholder="Juan"
                               autocomplete="given-name" required autofocus />
                        <span asp-validation-for="Input.Nombre" class="text-error text-xs"></span>
                    </div>
                    <div class="form-control gap-1.5">
                        <label class="text-[11px] font-bold uppercase tracking-widest text-base-content/35" for="regApellidos">Apellidos</label>
                        <input asp-for="Input.Apellidos" id="regApellidos" type="text"
                               class="input input-bordered rounded-xl h-11 text-sm border-base-300/15" placeholder="García"
                               autocomplete="family-name" required />
                        <span asp-validation-for="Input.Apellidos" class="text-error text-xs"></span>
                    </div>
                </div>

                <div class="form-control gap-1.5">
                    <label class="text-[11px] font-bold uppercase tracking-widest text-base-content/35" for="regEmail">Correo electrónico</label>
                    <label class="input input-bordered flex items-center gap-3 rounded-xl h-11 border-base-300/15 focus-within:border-primary/30">
                        <i class="fa-solid fa-envelope text-primary/30 text-xs"></i>
                        <input asp-for="Input.Email" id="regEmail" type="email" class="grow text-sm"
                               placeholder="tu@correo.com" autocomplete="email" required />
                    </label>
                    <span asp-validation-for="Input.Email" class="text-error text-xs"></span>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div class="form-control gap-1.5">
                        <label class="text-[11px] font-bold uppercase tracking-widest text-base-content/35" for="regPassword">Contraseña</label>
                        <label class="input input-bordered flex items-center gap-2 rounded-xl h-11 border-base-300/15 focus-within:border-primary/30">
                            <i class="fa-solid fa-lock text-primary/30 text-xs"></i>
                            <input asp-for="Input.Password" id="regPassword" type="password" class="grow text-sm"
                                   placeholder="Mínimo 6 car." autocomplete="new-password" required />
                            <button type="button" onclick="togglePassword('regPassword', 'eyeIconReg')"
                                    class="btn btn-ghost btn-xs btn-circle text-base-content/20 hover:text-primary" tabindex="-1">
                                <i id="eyeIconReg" class="fa-solid fa-eye text-xs"></i>
                            </button>
                        </label>
                        <span asp-validation-for="Input.Password" class="text-error text-xs"></span>
                    </div>
                    <div class="form-control gap-1.5">
                        <label class="text-[11px] font-bold uppercase tracking-widest text-base-content/35" for="regConfirm">Confirmar</label>
                        <label class="input input-bordered flex items-center gap-2 rounded-xl h-11 border-base-300/15 focus-within:border-primary/30">
                            <i class="fa-solid fa-lock text-primary/30 text-xs"></i>
                            <input asp-for="Input.ConfirmPassword" id="regConfirm" type="password" class="grow text-sm"
                                   placeholder="Repite" autocomplete="new-password" required />
                            <button type="button" onclick="togglePassword('regConfirm', 'eyeIconConfirm')"
                                    class="btn btn-ghost btn-xs btn-circle text-base-content/20 hover:text-primary" tabindex="-1">
                                <i id="eyeIconConfirm" class="fa-solid fa-eye text-xs"></i>
                            </button>
                        </label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-error text-xs"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-full rounded-xl font-bold h-12 text-sm tracking-wide mt-2">
                    Crear cuenta
                    <i class="fa-solid fa-arrow-right ml-1 text-xs"></i>
                </button>
            </form>

            <p class="text-center text-sm text-base-content/30 mt-6">
                ¿Ya tienes cuenta?
                <a asp-page="/Login" class="text-primary font-bold hover:text-primary/80 transition-colors">Inicia sesión</a>
            </p>
        </div>
    </div>

    <!-- Panel derecho: branding (solo desktop) -->
    <div class="hidden lg:flex lg:w-5/12 relative overflow-hidden items-center justify-center p-12">
        <div class="absolute inset-0 bg-gradient-to-bl from-primary/8 via-base-100 to-accent/3"></div>
        <div class="absolute top-1/3 right-1/4 w-64 h-64 rounded-full bg-primary/5 blur-[90px]"></div>
        <div class="absolute bottom-1/4 left-1/4 w-48 h-48 rounded-full bg-accent/4 blur-[70px]"></div>
        
        <div class="relative z-10 max-w-xs text-center">
            <div class="w-20 h-20 rounded-3xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-glow mx-auto mb-8 animate-float">
                <i class="fa-solid fa-user-plus text-4xl text-base-100"></i>
            </div>
            <h2 class="text-3xl font-black tracking-tighter mb-3">
                Únete a <span class="text-gradient-emerald">PandaDaw</span>
            </h2>
            <p class="text-base-content/30 text-sm font-medium leading-relaxed mb-8">
                Accede a ofertas exclusivas, seguimiento de pedidos y mucho más.
            </p>
            <div class="space-y-3 text-left">
                <div class="flex items-center gap-3 bg-base-300/5 rounded-xl p-3 border border-base-300/8">
                    <span class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-check text-primary text-xs"></i>
                    </span>
                    <span class="text-xs font-medium text-base-content/40">Acceso a ofertas exclusivas</span>
                </div>
                <div class="flex items-center gap-3 bg-base-300/5 rounded-xl p-3 border border-base-300/8">
                    <span class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-check text-primary text-xs"></i>
                    </span>
                    <span class="text-xs font-medium text-base-content/40">Seguimiento de pedidos en tiempo real</span>
                </div>
                <div class="flex items-center gap-3 bg-base-300/5 rounded-xl p-3 border border-base-300/8">
                    <span class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-check text-primary text-xs"></i>
                    </span>
                    <span class="text-xs font-medium text-base-content/40">Lista de favoritos personalizada</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
    </script>
}
