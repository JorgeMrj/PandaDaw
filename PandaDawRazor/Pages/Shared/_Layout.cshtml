<!DOCTYPE html>
<html lang="es" data-theme="pandadaw">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - PandaDaw</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }</style>
</head>
<body class="min-h-screen flex flex-col">
    <!-- Barra decorativa gradiente superior -->
    <div class="h-0.5 bg-gradient-to-r from-primary via-secondary to-accent"></div>

    <!-- Navbar -->
    <nav class="navbar bg-white/80 backdrop-blur-2xl border-b border-base-300/40 px-4 lg:px-10 sticky top-0 z-50 shadow-sm min-h-[4rem]">
        <!-- Logo -->
        <div class="flex-none">
            <a asp-page="/Index" class="flex items-center gap-3 group">
                <span class="w-10 h-10 rounded-2xl bg-gradient-to-br from-primary via-primary to-secondary flex items-center justify-center shadow-lg group-hover:shadow-xl transition-shadow duration-300">
                    <i class="fa-solid fa-paw text-white text-base"></i>
                </span>
                <span class="text-xl font-extrabold tracking-tight text-gradient-brand hidden sm:inline">PandaDaw</span>
            </a>
        </div>

        <!-- Buscador -->
        <div class="flex-1 flex justify-center px-6">
            <form method="get" asp-page="/Index" class="w-full max-w-xl">
                <div class="relative group">
                    <input type="text" name="buscar" placeholder="Buscar productos..." 
                           class="input input-bordered w-full pl-11 pr-4 bg-base-200/50 focus:bg-white border-base-300/50 rounded-2xl h-11 text-sm placeholder:text-base-content/30 transition-all duration-300" />
                    <i class="fa-solid fa-search absolute left-4 top-1/2 -translate-y-1/2 text-base-content/30 text-sm group-focus-within:text-primary transition-colors duration-200"></i>
                </div>
            </form>
        </div>

        <!-- Acciones derecha -->
        <div class="flex-none flex items-center gap-1.5">
            <a asp-page="/Favoritos" class="btn btn-ghost btn-circle btn-sm hover:bg-error/8 transition-all duration-200" title="Favoritos">
                <i class="fa-regular fa-heart text-base text-base-content/50 hover:text-error"></i>
            </a>
            <a asp-page="/Carrito" class="btn btn-ghost btn-circle btn-sm hover:bg-primary/8 transition-all duration-200" title="Carrito">
                <i class="fa-solid fa-bag-shopping text-base text-base-content/50"></i>
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="dropdown dropdown-end ml-2">
                    <button tabindex="0" class="btn btn-ghost btn-circle avatar">
                        <div class="w-9 rounded-full ring-2 ring-primary/25 ring-offset-base-100 ring-offset-2">
                            <img src="https://api.dicebear.com/7.x/initials/svg?seed=@Context.Session.GetString("UserName")&backgroundColor=166534&textColor=ffffff" alt="Avatar" />
                        </div>
                    </button>
                    <ul tabindex="0" class="dropdown-content menu bg-white rounded-2xl z-50 w-60 p-3 shadow-xl border border-base-300/40 mt-3">
                        <li class="px-3 py-3 mb-1.5">
                            <div class="flex flex-col gap-0.5 hover:bg-transparent cursor-default p-0">
                                <span class="font-bold text-sm text-base-content">@Context.Session.GetString("UserName")</span>
                                <span class="text-xs text-base-content/45">Cuenta personal</span>
                            </div>
                        </li>
                        <div class="h-px bg-base-300/40 mx-2 mb-1.5"></div>
                        @if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <li><a asp-page="/AdminPanel" class="rounded-xl text-sm py-2.5"><i class="fa-solid fa-shield-halved mr-2.5 text-primary/60 text-xs w-4"></i>Panel Admin</a></li>
                        }
                        <li><a asp-page="/Pedidos" class="rounded-xl text-sm py-2.5"><i class="fa-solid fa-box mr-2.5 text-primary/60 text-xs w-4"></i>Mis Pedidos</a></li>
                        <li><a asp-page="/Favoritos" class="rounded-xl text-sm py-2.5"><i class="fa-solid fa-heart mr-2.5 text-error/50 text-xs w-4"></i>Favoritos</a></li>
                        <div class="h-px bg-base-300/40 mx-2 my-1.5"></div>
                        <li>
                            <a asp-page="/Logout" class="text-error/80 hover:text-error rounded-xl text-sm py-2.5">
                                <i class="fa-solid fa-right-from-bracket mr-2.5 text-xs w-4"></i>Cerrar sesión
                            </a>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <a asp-page="/Login" class="btn btn-primary btn-sm ml-2 rounded-xl shadow-md font-semibold gap-1.5">
                    <i class="fa-solid fa-right-to-bracket text-xs"></i>
                    Entrar
                </a>
            }
        </div>
    </nav>

    <!-- Contenido principal -->
    <main class="flex-1">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="border-t border-base-300/40 bg-gradient-to-b from-white to-base-200/80">
        <div class="max-w-7xl mx-auto px-6 py-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
                <!-- Brand -->
                <div class="flex items-center gap-3">
                    <span class="w-11 h-11 rounded-2xl bg-gradient-to-br from-primary via-primary to-secondary flex items-center justify-center shadow-lg">
                        <i class="fa-solid fa-paw text-white text-base"></i>
                    </span>
                    <div>
                        <p class="font-extrabold text-base-content tracking-tight text-lg">PandaDaw</p>
                        <p class="text-xs text-base-content/40 font-medium">Tu tienda tech premium</p>
                    </div>
                </div>
                <!-- Social -->
                <div class="flex items-center justify-center gap-4">
                    <a href="#" class="w-9 h-9 rounded-xl bg-base-200/80 flex items-center justify-center text-base-content/40 hover:bg-primary hover:text-white transition-all duration-300">
                        <i class="fa-brands fa-instagram text-sm"></i>
                    </a>
                    <a href="#" class="w-9 h-9 rounded-xl bg-base-200/80 flex items-center justify-center text-base-content/40 hover:bg-primary hover:text-white transition-all duration-300">
                        <i class="fa-brands fa-twitter text-sm"></i>
                    </a>
                    <a href="#" class="w-9 h-9 rounded-xl bg-base-200/80 flex items-center justify-center text-base-content/40 hover:bg-primary hover:text-white transition-all duration-300">
                        <i class="fa-brands fa-github text-sm"></i>
                    </a>
                    <a href="#" class="w-9 h-9 rounded-xl bg-base-200/80 flex items-center justify-center text-base-content/40 hover:bg-primary hover:text-white transition-all duration-300">
                        <i class="fa-brands fa-youtube text-sm"></i>
                    </a>
                </div>
                <!-- Copyright -->
                <p class="text-xs text-base-content/35 text-right font-medium">&copy; 2025 PandaDaw. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>