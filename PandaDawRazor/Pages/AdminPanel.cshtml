@page
@model AdminPanelModel
@{
    ViewData["Title"] = "Panel de Administración";
    Layout = "_Layout";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
        <div>
            <h1 class="text-2xl sm:text-3xl font-black tracking-tight flex items-center gap-2.5">
                <i class="fa-solid fa-shield-halved text-accent/60 text-xl"></i>
                Admin Panel
            </h1>
            <p class="text-sm text-base-content/30 font-medium mt-1">Gestiona productos de la tienda</p>
        </div>
        <button onclick="modal_crear.showModal()" class="btn btn-primary btn-sm rounded-xl font-bold gap-1.5 h-9 min-h-0 px-5 text-xs">
            <i class="fa-solid fa-plus text-[10px]"></i> Nuevo Producto
        </button>
    </div>

    <!-- Mensajes -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success mb-6 rounded-xl text-sm">
            <i class="fa-solid fa-check-circle text-sm"></i>
            <span>@Model.SuccessMessage</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error mb-6 rounded-xl text-sm">
            <i class="fa-solid fa-exclamation-circle text-sm"></i>
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <!-- Stats -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
        <div class="bg-base-300/5 rounded-xl p-4 border border-base-300/6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-[9px] font-bold uppercase tracking-widest text-base-content/25">Productos</p>
                    <span class="text-2xl font-black text-primary price-display">@Model.Productos.Count</span>
                </div>
                <i class="fa-solid fa-box text-primary/20 text-lg"></i>
            </div>
        </div>
        <div class="bg-base-300/5 rounded-xl p-4 border border-base-300/6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-[9px] font-bold uppercase tracking-widest text-base-content/25">Activos</p>
                    <span class="text-2xl font-black text-success price-display">@Model.Productos.Count(p => !p.IsDeleted)</span>
                </div>
                <i class="fa-solid fa-check-circle text-success/20 text-lg"></i>
            </div>
        </div>
        <div class="bg-base-300/5 rounded-xl p-4 border border-base-300/6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-[9px] font-bold uppercase tracking-widest text-base-content/25">Eliminados</p>
                    <span class="text-2xl font-black text-error price-display">@Model.Productos.Count(p => p.IsDeleted)</span>
                </div>
                <i class="fa-solid fa-trash text-error/20 text-lg"></i>
            </div>
        </div>
        <div class="bg-base-300/5 rounded-xl p-4 border border-base-300/6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-[9px] font-bold uppercase tracking-widest text-base-content/25">Sin Stock</p>
                    <span class="text-2xl font-black text-warning price-display">@Model.Productos.Count(p => p.Stock == 0 && !p.IsDeleted)</span>
                </div>
                <i class="fa-solid fa-exclamation-triangle text-warning/20 text-lg"></i>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="bg-base-300/3 rounded-xl border border-base-300/6 p-4 mb-6">
        <form method="get" class="flex flex-col sm:flex-row gap-3 items-center">
            <div class="relative flex-1 w-full">
                <i class="fa-solid fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-base-content/20 text-xs"></i>
                <input type="text" name="filtro" value="@Model.Filtro" placeholder="Buscar productos..."
                       class="input input-bordered w-full pl-10 rounded-xl h-10 text-sm border-base-300/10" />
            </div>
            <label class="flex items-center gap-2 cursor-pointer shrink-0">
                <input type="checkbox" name="mostrarEliminados" value="true" @(Model.MostrarEliminados ? "checked" : "")
                       class="checkbox checkbox-primary checkbox-sm rounded-lg" />
                <span class="text-xs font-semibold text-base-content/40">Eliminados</span>
            </label>
            <button type="submit" class="btn btn-primary btn-sm rounded-xl font-bold text-xs h-9 min-h-0 px-4 gap-1">
                <i class="fa-solid fa-filter text-[9px]"></i> Filtrar
            </button>
        </form>
    </div>

    <!-- Tabla / Cards -->
    @if (Model.Productos.Any())
    {
        <!-- Vista tabla desktop -->
        <div class="hidden md:block bg-base-300/3 rounded-2xl border border-base-300/8 overflow-hidden">
            <table class="table table-zebra w-full">
                <thead>
                    <tr class="border-b border-base-300/10">
                        <th class="bg-base-300/5 py-3 px-4">ID</th>
                        <th class="bg-base-300/5 py-3">Producto</th>
                        <th class="bg-base-300/5 py-3">Categoría</th>
                        <th class="bg-base-300/5 py-3">Precio</th>
                        <th class="bg-base-300/5 py-3">Stock</th>
                        <th class="bg-base-300/5 py-3">Estado</th>
                        <th class="bg-base-300/5 py-3 px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var producto in Model.Productos)
                    {
                        <tr class="@(producto.IsDeleted ? "opacity-35" : "") border-b border-base-300/5 hover:bg-base-300/5 transition-colors">
                            <td class="font-mono text-xs text-base-content/30 px-4">@producto.Id</td>
                            <td>
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg bg-base-300/10 overflow-hidden shrink-0 border border-base-300/6">
                                        @if (!string.IsNullOrEmpty(producto.Imagen))
                                        {
                                            <img src="@producto.Imagen" alt="" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <div class="w-full h-full flex items-center justify-center"><i class="fa-solid fa-image text-base-content/10 text-xs"></i></div>
                                        }
                                    </div>
                                    <div class="min-w-0">
                                        <p class="font-bold text-sm line-clamp-1">@producto.Nombre</p>
                                        @if (!string.IsNullOrEmpty(producto.Descripcion))
                                        {
                                            <p class="text-[10px] text-base-content/25 line-clamp-1">@producto.Descripcion</p>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td><span class="text-[10px] font-bold uppercase tracking-wider text-base-content/35 bg-base-300/8 px-2 py-0.5 rounded-md">@producto.Category</span></td>
                            <td class="font-bold text-sm price-display">@producto.Precio.ToString("C", new System.Globalization.CultureInfo("es-ES"))</td>
                            <td>
                                @if (producto.Stock > 10)
                                {
                                    <span class="text-sm font-bold text-success">@producto.Stock</span>
                                }
                                else if (producto.Stock > 0)
                                {
                                    <span class="text-sm font-bold text-warning">@producto.Stock</span>
                                }
                                else
                                {
                                    <span class="text-sm font-bold text-error">0</span>
                                }
                            </td>
                            <td>
                                @if (producto.IsDeleted)
                                {
                                    <span class="text-[9px] font-bold text-error uppercase tracking-wider">Eliminado</span>
                                }
                                else
                                {
                                    <span class="text-[9px] font-bold text-success uppercase tracking-wider">Activo</span>
                                }
                            </td>
                            <td class="px-4">
                                <div class="flex gap-1">
                                    @if (!producto.IsDeleted)
                                    {
                                        <button onclick="abrirModalEditar(@producto.Id, '@producto.Nombre.Replace("'", "\\'")' , '@(producto.Descripcion?.Replace("'", "\\'") ?? "")', @producto.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture), @producto.Stock, '@producto.Category', '@(producto.Imagen ?? "")')"
                                                class="w-8 h-8 rounded-lg flex items-center justify-center text-info/60 hover:text-info hover:bg-info/8 transition-all" title="Editar">
                                            <i class="fa-solid fa-edit text-xs"></i>
                                        </button>
                                        <form method="post" asp-page-handler="Eliminar" asp-route-id="@producto.Id" class="inline">
                                            <button type="submit" class="w-8 h-8 rounded-lg flex items-center justify-center text-error/40 hover:text-error hover:bg-error/8 transition-all"
                                                    title="Eliminar" onclick="return confirm('¿Eliminar este producto?')">
                                                <i class="fa-solid fa-trash text-xs"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Restaurar" asp-route-id="@producto.Id" class="inline">
                                            <button type="submit" class="w-8 h-8 rounded-lg flex items-center justify-center text-success/60 hover:text-success hover:bg-success/8 transition-all" title="Restaurar">
                                                <i class="fa-solid fa-undo text-xs"></i>
                                            </button>
                                        </form>
                                    }
                                    <a asp-page="/Detalle" asp-route-id="@producto.Id" class="w-8 h-8 rounded-lg flex items-center justify-center text-primary/40 hover:text-primary hover:bg-primary/8 transition-all" title="Ver">
                                        <i class="fa-solid fa-eye text-xs"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Vista cards móvil -->
        <div class="md:hidden flex flex-col gap-3">
            @foreach (var producto in Model.Productos)
            {
                <div class="flex gap-3 p-3 rounded-xl bg-base-300/3 border border-base-300/8 @(producto.IsDeleted ? "opacity-35" : "")">
                    <div class="w-16 h-16 rounded-lg bg-base-300/10 overflow-hidden shrink-0 border border-base-300/6">
                        @if (!string.IsNullOrEmpty(producto.Imagen))
                        {
                            <img src="@producto.Imagen" alt="" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center"><i class="fa-solid fa-image text-base-content/10"></i></div>
                        }
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-bold text-sm line-clamp-1">@producto.Nombre</p>
                        <div class="flex items-center gap-2 mt-0.5">
                            <span class="text-sm font-black text-primary price-display">@producto.Precio.ToString("C", new System.Globalization.CultureInfo("es-ES"))</span>
                            <span class="text-[9px] font-bold uppercase tracking-wider text-base-content/25">@producto.Category</span>
                        </div>
                        <div class="flex items-center justify-between mt-2">
                            <div class="flex items-center gap-2">
                                <span class="text-xs font-bold @(producto.Stock > 0 ? "text-success" : "text-error")">Stock: @producto.Stock</span>
                                <span class="text-[9px] font-bold @(producto.IsDeleted ? "text-error" : "text-success") uppercase">@(producto.IsDeleted ? "Eliminado" : "Activo")</span>
                            </div>
                            <div class="flex gap-1">
                                @if (!producto.IsDeleted)
                                {
                                    <button onclick="abrirModalEditar(@producto.Id, '@producto.Nombre.Replace("'", "\\'")' , '@(producto.Descripcion?.Replace("'", "\\'") ?? "")', @producto.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture), @producto.Stock, '@producto.Category', '@(producto.Imagen ?? "")')"
                                            class="w-7 h-7 rounded-md flex items-center justify-center text-info/60 hover:text-info hover:bg-info/8">
                                        <i class="fa-solid fa-edit text-[10px]"></i>
                                    </button>
                                    <form method="post" asp-page-handler="Eliminar" asp-route-id="@producto.Id" class="inline">
                                        <button type="submit" class="w-7 h-7 rounded-md flex items-center justify-center text-error/40 hover:text-error hover:bg-error/8"
                                                onclick="return confirm('¿Eliminar?')">
                                            <i class="fa-solid fa-trash text-[10px]"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Restaurar" asp-route-id="@producto.Id" class="inline">
                                        <button type="submit" class="w-7 h-7 rounded-md flex items-center justify-center text-success/60 hover:text-success hover:bg-success/8">
                                            <i class="fa-solid fa-undo text-[10px]"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-16">
            <i class="fa-solid fa-box-open text-3xl text-base-content/10 mb-3"></i>
            <p class="font-bold text-sm text-base-content/35">No hay productos</p>
        </div>
    }
</div>

<!-- Modal Crear -->
<dialog id="modal_crear" class="modal">
    <div class="modal-box w-11/12 max-w-lg rounded-2xl p-6">
        <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-3 top-3 text-base-content/30">✕</button></form>
        <h3 class="font-black text-lg mb-6 flex items-center gap-2">
            <span class="w-7 h-7 rounded-lg bg-primary/8 flex items-center justify-center"><i class="fa-solid fa-plus text-primary text-[10px]"></i></span>
            Nuevo Producto
        </h3>
        <form method="post" asp-page-handler="Crear" class="space-y-4">
            <div class="form-control gap-1">
                <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">Nombre *</label>
                <input type="text" name="ProductoInput.Nombre" required class="input input-bordered w-full rounded-xl h-10 text-sm border-base-300/12" placeholder="Nombre del producto" />
            </div>
            <div class="form-control gap-1">
                <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">Descripción</label>
                <textarea name="ProductoInput.Descripcion" rows="2" class="textarea textarea-bordered w-full rounded-xl text-sm border-base-300/12" placeholder="Descripción"></textarea>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div class="form-control gap-1">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">Precio *</label>
                    <input type="number" name="ProductoInput.Precio" step="0.01" min="0" required class="input input-bordered w-full rounded-xl h-10 text-sm border-base-300/12" placeholder="0.00" />
                </div>
                <div class="form-control gap-1">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">Stock *</label>
                    <input type="number" name="ProductoInput.Stock" min="0" required class="input input-bordered w-full rounded-xl h-10 text-sm border-base-300/12" placeholder="0" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div class="form-control gap-1">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">Categoría *</label>
                    <select name="ProductoInput.Categoria" required class="select select-bordered w-full rounded-xl h-10 text-sm border-base-300/12 min-h-0">
                        <option value="">Seleccionar</option>
                        <option value="Audio">Audio</option>
                        <option value="Imagen">Imagen</option>
                        <option value="Smartphones">Smartphones</option>
                        <option value="Laptops">Laptops</option>
                        <option value="Gaming">Gaming</option>
                    </select>
                </div>
                <div class="form-control gap-1">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">URL Imagen</label>
                    <input type="url" name="ProductoInput.ImagenUrl" class="input input-bordered w-full rounded-xl h-10 text-sm border-base-300/12" placeholder="https://..." />
                </div>
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="modal_crear.close()" class="btn btn-ghost btn-sm rounded-xl">Cancelar</button>
                <button type="submit" class="btn btn-primary btn-sm rounded-xl font-bold gap-1 px-5">
                    <i class="fa-solid fa-save text-[10px]"></i> Crear
                </button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<!-- Modal Editar -->
<dialog id="modal_editar" class="modal">
    <div class="modal-box w-11/12 max-w-lg rounded-2xl p-6">
        <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-3 top-3 text-base-content/30">✕</button></form>
        <h3 class="font-black text-lg mb-6 flex items-center gap-2">
            <span class="w-7 h-7 rounded-lg bg-info/8 flex items-center justify-center"><i class="fa-solid fa-edit text-info text-[10px]"></i></span>
            Editar Producto
        </h3>
        <form method="post" asp-page-handler="Editar" id="form_editar" class="space-y-4">
            <input type="hidden" name="id" id="editar_id" />
            <div class="form-control gap-1">
                <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">Nombre *</label>
                <input type="text" name="ProductoInput.Nombre" id="editar_nombre" required class="input input-bordered w-full rounded-xl h-10 text-sm border-base-300/12" />
            </div>
            <div class="form-control gap-1">
                <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">Descripción</label>
                <textarea name="ProductoInput.Descripcion" id="editar_descripcion" rows="2" class="textarea textarea-bordered w-full rounded-xl text-sm border-base-300/12"></textarea>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div class="form-control gap-1">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">Precio *</label>
                    <input type="number" name="ProductoInput.Precio" id="editar_precio" step="0.01" min="0" required class="input input-bordered w-full rounded-xl h-10 text-sm border-base-300/12" />
                </div>
                <div class="form-control gap-1">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">Stock *</label>
                    <input type="number" name="ProductoInput.Stock" id="editar_stock" min="0" required class="input input-bordered w-full rounded-xl h-10 text-sm border-base-300/12" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div class="form-control gap-1">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">Categoría *</label>
                    <select name="ProductoInput.Categoria" id="editar_categoria" required class="select select-bordered w-full rounded-xl h-10 text-sm border-base-300/12 min-h-0">
                        <option value="Audio">Audio</option>
                        <option value="Imagen">Imagen</option>
                        <option value="Smartphones">Smartphones</option>
                        <option value="Laptops">Laptops</option>
                        <option value="Gaming">Gaming</option>
                    </select>
                </div>
                <div class="form-control gap-1">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-base-content/30">URL Imagen</label>
                    <input type="url" name="ProductoInput.ImagenUrl" id="editar_imagen" class="input input-bordered w-full rounded-xl h-10 text-sm border-base-300/12" />
                </div>
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="modal_editar.close()" class="btn btn-ghost btn-sm rounded-xl">Cancelar</button>
                <button type="submit" class="btn btn-info btn-sm rounded-xl font-bold gap-1 px-5">
                    <i class="fa-solid fa-save text-[10px]"></i> Guardar
                </button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

@section Scripts {
    <script>
        function abrirModalEditar(id, nombre, descripcion, precio, stock, categoria, imagen) {
            document.getElementById('editar_id').value = id;
            document.getElementById('editar_nombre').value = nombre;
            document.getElementById('editar_descripcion').value = descripcion;
            document.getElementById('editar_precio').value = precio;
            document.getElementById('editar_stock').value = stock;
            document.getElementById('editar_categoria').value = categoria;
            document.getElementById('editar_imagen').value = imagen;
            document.getElementById('form_editar').action = '?handler=Editar&id=' + id;
            modal_editar.showModal();
        }
    </script>
}
