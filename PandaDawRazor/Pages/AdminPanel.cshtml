@page
@model AdminPanelModel
@{
    ViewData["Title"] = "Panel de Administración";
    Layout = "_Layout";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 mb-10">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="w-8 h-0.5 bg-primary rounded-full"></span>
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary/60">Administración</p>
            </div>
            <h1 class="text-3xl font-extrabold text-base-content tracking-tight flex items-center gap-3">
                <i class="fa-solid fa-shield-halved text-primary/80"></i>
                Panel de Admin
            </h1>
            <p class="text-base-content/40 mt-1.5 text-sm font-medium">Gestiona los productos de la tienda</p>
        </div>
        
        <button onclick="modal_crear.showModal()" class="btn btn-primary gap-2 rounded-2xl font-bold shadow-lg">
            <i class="fa-solid fa-plus text-xs"></i>
            Nuevo Producto
        </button>
    </div>

    <!-- Mensajes -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success mb-7 rounded-2xl">
            <i class="fa-solid fa-check-circle"></i>
            <span>@Model.SuccessMessage</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error mb-7 rounded-2xl">
            <i class="fa-solid fa-exclamation-circle"></i>
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <!-- Filtros -->
    <div class="card bg-white shadow-sm mb-7 rounded-2xl border-0">
        <div class="card-body p-5">
            <form method="get" class="flex flex-col sm:flex-row gap-4 items-center">
                <div class="form-control flex-1 w-full">
                    <div class="relative">
                        <input type="text" name="filtro" value="@Model.Filtro" placeholder="Buscar productos..." 
                               class="input input-bordered w-full pl-11 rounded-2xl h-11 text-sm bg-base-200/30" />
                        <i class="fa-solid fa-search absolute left-4 top-1/2 -translate-y-1/2 text-base-content/30 text-xs"></i>
                    </div>
                </div>
                <label class="label cursor-pointer gap-2.5 px-3">
                    <input type="checkbox" name="mostrarEliminados" value="true" @(Model.MostrarEliminados ? "checked" : "") 
                           class="checkbox checkbox-primary checkbox-sm rounded-lg" />
                    <span class="label-text text-xs font-semibold">Mostrar eliminados</span>
                </label>
                <button type="submit" class="btn btn-primary btn-sm rounded-2xl font-bold text-xs gap-1.5">
                    <i class="fa-solid fa-filter text-[10px]"></i>
                    Filtrar
                </button>
            </form>
        </div>
    </div>

    <!-- Estadísticas -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-7">
        <div class="stat bg-white rounded-3xl shadow-md border-0 py-5">
            <div class="stat-figure text-primary">
                <i class="fa-solid fa-box text-xl"></i>
            </div>
            <div class="stat-title">Total Productos</div>
            <div class="stat-value text-primary text-2xl">@Model.Productos.Count</div>
        </div>
        <div class="stat bg-white rounded-3xl shadow-md border-0 py-5">
            <div class="stat-figure text-success">
                <i class="fa-solid fa-check-circle text-xl"></i>
            </div>
            <div class="stat-title">Activos</div>
            <div class="stat-value text-success text-2xl">@Model.Productos.Count(p => !p.IsDeleted)</div>
        </div>
        <div class="stat bg-white rounded-3xl shadow-md border-0 py-5">
            <div class="stat-figure text-error">
                <i class="fa-solid fa-trash text-xl"></i>
            </div>
            <div class="stat-title">Eliminados</div>
            <div class="stat-value text-error text-2xl">@Model.Productos.Count(p => p.IsDeleted)</div>
        </div>
        <div class="stat bg-white rounded-3xl shadow-md border-0 py-5">
            <div class="stat-figure text-warning">
                <i class="fa-solid fa-exclamation-triangle text-xl"></i>
            </div>
            <div class="stat-title">Sin Stock</div>
            <div class="stat-value text-warning text-2xl">@Model.Productos.Count(p => p.Stock == 0 && !p.IsDeleted)</div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card bg-white shadow-md overflow-hidden rounded-3xl border-0">
        <div class="overflow-x-auto">
            <table class="table table-zebra">
                <thead class="bg-base-200">
                    <tr>
                        <th>ID</th>
                        <th>Imagen</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var producto in Model.Productos)
                    {
                        <tr class="@(producto.IsDeleted ? "opacity-40" : "") hover:bg-base-200/30 transition-colors">
                            <td class="font-mono text-xs text-base-content/50">@producto.Id</td>
                            <td>
                                <div class="avatar">
                                    <div class="w-11 h-11 rounded-xl bg-base-200/60">
                                        @if (!string.IsNullOrEmpty(producto.Imagen))
                                        {
                                            <img src="@producto.Imagen" alt="@producto.Nombre" class="object-cover" />
                                        }
                                        else
                                        {
                                            <div class="w-full h-full flex items-center justify-center">
                                                <i class="fa-solid fa-image text-base-content/20 text-xs"></i>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="font-bold text-sm line-clamp-1">@producto.Nombre</div>
                                @if (!string.IsNullOrEmpty(producto.Descripcion))
                                {
                                    <div class="text-[11px] text-base-content/40 line-clamp-1 mt-0.5">@producto.Descripcion</div>
                                }
                            </td>
                            <td>
                                <span class="badge badge-outline badge-sm rounded-xl text-[10px] font-bold uppercase tracking-wider">@producto.Category</span>
                            </td>
                            <td class="font-bold text-sm">
                                @producto.Precio.ToString("C", new System.Globalization.CultureInfo("es-ES"))
                            </td>
                            <td>
                                @if (producto.Stock > 10)
                                {
                                    <span class="badge badge-success badge-sm rounded-xl font-bold text-[10px]">@producto.Stock</span>
                                }
                                else if (producto.Stock > 0)
                                {
                                    <span class="badge badge-warning badge-sm rounded-xl font-bold text-[10px]">@producto.Stock</span>
                                }
                                else
                                {
                                    <span class="badge badge-error badge-sm rounded-xl font-bold text-[10px]">0</span>
                                }
                            </td>
                            <td>
                                @if (producto.IsDeleted)
                                {
                                    <span class="badge badge-error gap-1 rounded-xl font-bold text-[10px] uppercase tracking-wider">
                                        <i class="fa-solid fa-trash text-[8px]"></i> Eliminado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-success gap-1 rounded-xl font-bold text-[10px] uppercase tracking-wider">
                                        <i class="fa-solid fa-check text-[8px]"></i> Activo
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="flex gap-1.5">
                                    @if (!producto.IsDeleted)
                                    {
                                        <button onclick="abrirModalEditar(@producto.Id, '@producto.Nombre.Replace("'", "\\'")' , '@(producto.Descripcion?.Replace("'", "\\'") ?? "")', @producto.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture), @producto.Stock, '@producto.Category', '@(producto.Imagen ?? "")')" 
                                                class="btn btn-ghost btn-sm btn-square rounded-xl hover:bg-info/8" title="Editar">
                                            <i class="fa-solid fa-edit text-info text-xs"></i>
                                        </button>
                                        <form method="post" asp-page-handler="Eliminar" asp-route-id="@producto.Id" class="inline">
                                            <button type="submit" class="btn btn-ghost btn-sm btn-square rounded-xl hover:bg-error/8" 
                                                    title="Eliminar" onclick="return confirm('¿Seguro que quieres eliminar este producto?')">
                                                <i class="fa-solid fa-trash text-error text-xs"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Restaurar" asp-route-id="@producto.Id" class="inline">
                                            <button type="submit" class="btn btn-ghost btn-sm btn-square rounded-xl hover:bg-success/8" title="Restaurar">
                                                <i class="fa-solid fa-undo text-success text-xs"></i>
                                            </button>
                                        </form>
                                    }
                                    <a asp-page="/Detalle" asp-route-id="@producto.Id" class="btn btn-ghost btn-sm btn-square rounded-xl hover:bg-primary/8" title="Ver">
                                        <i class="fa-solid fa-eye text-primary text-xs"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!Model.Productos.Any())
        {
            <div class="p-16 text-center">
                <div class="w-20 h-20 rounded-3xl bg-base-200/50 flex items-center justify-center mx-auto mb-4">
                    <i class="fa-solid fa-box-open text-4xl text-base-content/15"></i>
                </div>
                <h3 class="text-lg font-extrabold text-base-content/50 tracking-tight">No hay productos</h3>
                <p class="text-base-content/35 text-sm mt-1">Crea tu primer producto para empezar</p>
            </div>
        }
    </div>
</div>

<!-- Modal Crear -->
<dialog id="modal_crear" class="modal">
    <div class="modal-box w-11/12 max-w-2xl rounded-3xl">
        <form method="dialog">
            <button class="btn btn-sm btn-circle btn-ghost absolute right-4 top-4">✕</button>
        </form>
        <h3 class="font-extrabold text-xl mb-7 flex items-center gap-2.5 tracking-tight">
            <span class="w-8 h-8 rounded-xl bg-primary/8 flex items-center justify-center">
                <i class="fa-solid fa-plus text-primary text-xs"></i>
            </span>
            Crear Nuevo Producto
        </h3>
        
        <form method="post" asp-page-handler="Crear">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="form-control md:col-span-2 gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Nombre *</span>
                    </label>
                    <input type="text" name="ProductoInput.Nombre" required
                           class="input input-bordered w-full rounded-2xl h-11 text-sm bg-base-200/30" placeholder="Nombre del producto" />
                </div>
                
                <div class="form-control md:col-span-2 gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Descripción</span>
                    </label>
                    <textarea name="ProductoInput.Descripcion" rows="3"
                              class="textarea textarea-bordered w-full rounded-2xl text-sm bg-base-200/30" placeholder="Descripción del producto"></textarea>
                </div>
                
                <div class="form-control gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Precio *</span>
                    </label>
                    <input type="number" name="ProductoInput.Precio" step="0.01" min="0" required
                           class="input input-bordered w-full rounded-2xl h-11 text-sm bg-base-200/30" placeholder="0.00" />
                </div>
                
                <div class="form-control gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Stock *</span>
                    </label>
                    <input type="number" name="ProductoInput.Stock" min="0" required
                           class="input input-bordered w-full rounded-2xl h-11 text-sm bg-base-200/30" placeholder="0" />
                </div>
                
                <div class="form-control gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Categoría *</span>
                    </label>
                    <select name="ProductoInput.Categoria" required class="select select-bordered w-full rounded-2xl h-11 text-sm bg-base-200/30">
                        <option value="">Seleccionar...</option>
                        <option value="Audio">Audio</option>
                        <option value="Imagen">Imagen</option>
                        <option value="Smartphones">Smartphones</option>
                        <option value="Laptops">Laptops</option>
                        <option value="Gaming">Gaming</option>
                    </select>
                </div>
                
                <div class="form-control gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">URL de Imagen</span>
                    </label>
                    <input type="url" name="ProductoInput.ImagenUrl"
                           class="input input-bordered w-full rounded-2xl h-11 text-sm bg-base-200/30" placeholder="https://..." />
                </div>
            </div>
            
            <div class="modal-action mt-7">
                <button type="button" onclick="modal_crear.close()" class="btn btn-ghost rounded-2xl font-semibold">Cancelar</button>
                <button type="submit" class="btn btn-primary gap-2 rounded-2xl font-bold shadow-md">
                    <i class="fa-solid fa-save text-xs"></i>
                    Crear Producto
                </button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

<!-- Modal Editar -->
<dialog id="modal_editar" class="modal">
    <div class="modal-box w-11/12 max-w-2xl rounded-3xl">
        <form method="dialog">
            <button class="btn btn-sm btn-circle btn-ghost absolute right-4 top-4">✕</button>
        </form>
        <h3 class="font-extrabold text-xl mb-7 flex items-center gap-2.5 tracking-tight">
            <span class="w-8 h-8 rounded-xl bg-info/8 flex items-center justify-center">
                <i class="fa-solid fa-edit text-info text-xs"></i>
            </span>
            Editar Producto
        </h3>
        
        <form method="post" asp-page-handler="Editar" id="form_editar">
            <input type="hidden" name="id" id="editar_id" />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="form-control md:col-span-2 gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Nombre *</span>
                    </label>
                    <input type="text" name="ProductoInput.Nombre" id="editar_nombre" required
                           class="input input-bordered w-full rounded-2xl h-11 text-sm bg-base-200/30" />
                </div>
                
                <div class="form-control md:col-span-2 gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Descripción</span>
                    </label>
                    <textarea name="ProductoInput.Descripcion" id="editar_descripcion" rows="3"
                              class="textarea textarea-bordered w-full rounded-2xl text-sm bg-base-200/30"></textarea>
                </div>
                
                <div class="form-control gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Precio *</span>
                    </label>
                    <input type="number" name="ProductoInput.Precio" id="editar_precio" step="0.01" min="0" required
                           class="input input-bordered w-full rounded-2xl h-11 text-sm bg-base-200/30" />
                </div>
                
                <div class="form-control gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Stock *</span>
                    </label>
                    <input type="number" name="ProductoInput.Stock" id="editar_stock" min="0" required
                           class="input input-bordered w-full rounded-2xl h-11 text-sm bg-base-200/30" />
                </div>
                
                <div class="form-control gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">Categoría *</span>
                    </label>
                    <select name="ProductoInput.Categoria" id="editar_categoria" required class="select select-bordered w-full rounded-2xl h-11 text-sm bg-base-200/30">
                        <option value="Audio">Audio</option>
                        <option value="Imagen">Imagen</option>
                        <option value="Smartphones">Smartphones</option>
                        <option value="Laptops">Laptops</option>
                        <option value="Gaming">Gaming</option>
                    </select>
                </div>
                
                <div class="form-control gap-1.5">
                    <label class="label">
                        <span class="label-text font-semibold text-xs uppercase tracking-wider text-base-content/60">URL de Imagen</span>
                    </label>
                    <input type="url" name="ProductoInput.ImagenUrl" id="editar_imagen"
                           class="input input-bordered w-full rounded-2xl h-11 text-sm bg-base-200/30" />
                </div>
            </div>
            
            <div class="modal-action mt-7">
                <button type="button" onclick="modal_editar.close()" class="btn btn-ghost rounded-2xl font-semibold">Cancelar</button>
                <button type="submit" class="btn btn-info gap-2 rounded-2xl font-bold shadow-md">
                    <i class="fa-solid fa-save text-xs"></i>
                    Guardar Cambios
                </button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

@section Scripts {
    <script>
        function abrirModalEditar(id, nombre, descripcion, precio, stock, categoria, imagen) {
            document.getElementById('editar_id').value = id;
            document.getElementById('editar_nombre').value = nombre;
            document.getElementById('editar_descripcion').value = descripcion;
            document.getElementById('editar_precio').value = precio;
            document.getElementById('editar_stock').value = stock;
            document.getElementById('editar_categoria').value = categoria;
            document.getElementById('editar_imagen').value = imagen;
            
            document.getElementById('form_editar').action = '?handler=Editar&id=' + id;
            
            modal_editar.showModal();
        }
    </script>
}
