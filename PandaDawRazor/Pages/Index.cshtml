@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
    Layout = "_Layout";
}

<div class="container mx-auto p-6">
    <!-- Cabecera con filtros -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
        <div>
            <h1 class="text-3xl font-bold text-base-content">Productos</h1>
            <p class="text-base-content/60">@Model.Productos.Count productos encontrados</p>
        </div>
        
        <!-- Filtros por categoría -->
        <div class="flex flex-wrap gap-2">
            <a asp-page="/Index" class="btn btn-sm @(Model.Categoria == null ? "btn-primary" : "btn-ghost")">
                Todos
            </a>
            <a asp-page="/Index" asp-route-categoria="Software" class="btn btn-sm @(Model.Categoria == "Software" ? "btn-primary" : "btn-ghost")">
                <i class="fa-solid fa-laptop-code mr-1"></i> Software
            </a>
            <a asp-page="/Index" asp-route-categoria="Samples" class="btn btn-sm @(Model.Categoria == "Samples" ? "btn-primary" : "btn-ghost")">
                <i class="fa-solid fa-music mr-1"></i> Samples
            </a>
            <a asp-page="/Index" asp-route-categoria="Plugins" class="btn btn-sm @(Model.Categoria == "Plugins" ? "btn-primary" : "btn-ghost")">
                <i class="fa-solid fa-plug mr-1"></i> Plugins
            </a>
            <a asp-page="/Index" asp-route-categoria="Hardware" class="btn btn-sm @(Model.Categoria == "Hardware" ? "btn-primary" : "btn-ghost")">
                <i class="fa-solid fa-microphone mr-1"></i> Hardware
            </a>
        </div>
    </div>

    <!-- Grid de productos -->
    @if (Model.Productos.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var producto in Model.Productos)
            {
                var esFavorito = Model.FavoritosMap.ContainsKey(producto.Id);
                var favoritoId = esFavorito ? Model.FavoritosMap[producto.Id] : 0;
                
                <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 group">
                    <!-- Imagen del producto -->
                    <figure class="relative h-48 bg-base-300">
                        @if (!string.IsNullOrEmpty(producto.Imagen))
                        {
                            <img src="@producto.Imagen" alt="@producto.Nombre" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <i class="fa-solid fa-music text-4xl text-primary/50"></i>
                            </div>
                        }
                        
                        <!-- Badge categoría -->
                        <span class="badge badge-primary absolute top-2 left-2">@producto.Category</span>
                        
                        <!-- Botón favorito -->
                        <form method="post" asp-page-handler="ToggleFavorito" class="absolute top-2 right-2">
                            <input type="hidden" name="productoId" value="@producto.Id" />
                            @if (esFavorito)
                            {
                                <input type="hidden" name="favoritoId" value="@favoritoId" />
                            }
                            <button type="submit" class="btn btn-circle btn-sm @(esFavorito ? "btn-error" : "btn-ghost bg-base-100/80")">
                                <i class="@(esFavorito ? "fa-solid" : "fa-regular") fa-heart"></i>
                            </button>
                        </form>
                    </figure>
                    
                    <div class="card-body p-4">
                        <!-- Nombre y precio -->
                        <a asp-page="/Detalle" asp-route-id="@producto.Id" class="card-title text-base hover:text-primary transition-colors">
                            @producto.Nombre
                        </a>
                        
                        <div class="flex items-center justify-between mt-2">
                            <span class="text-xl font-bold text-primary">@producto.Precio.ToString("C")</span>
                            
                            @if (producto.Stock > 0)
                            {
                                <span class="badge badge-success badge-outline badge-sm">En stock</span>
                            }
                            else
                            {
                                <span class="badge badge-error badge-outline badge-sm">Agotado</span>
                            }
                        </div>
                        
                        <!-- Acciones -->
                        <div class="card-actions mt-4">
                            <form method="post" asp-page-handler="AddToCart" class="w-full">
                                <input type="hidden" name="productoId" value="@producto.Id" />
                                <button type="submit" class="btn btn-primary btn-sm w-full" @(producto.Stock <= 0 ? "disabled" : "")>
                                    <i class="fa-solid fa-cart-plus mr-1"></i>
                                    Añadir al carrito
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-16">
            <i class="fa-solid fa-box-open text-6xl text-base-content/30 mb-4"></i>
            <h2 class="text-xl font-semibold text-base-content/70">No se encontraron productos</h2>
            <p class="text-base-content/50 mt-2">Intenta con otros filtros de búsqueda</p>
            <a asp-page="/Index" class="btn btn-primary mt-4">Ver todos los productos</a>
        </div>
    }
</div>
