@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
    Layout = "_Layout";
}

<div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Header con título y filtros -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8 mb-12">
        <div class="space-y-3">
            <h1 class="text-5xl font-bold text-primary">🐼 Catálogo</h1>
            <p class="text-lg text-base-content/70 font-medium">@Model.Productos.Count productos disponibles</p>
        </div>
        
        <!-- Filtros por categoría -->
        <div class="flex flex-wrap gap-3 justify-lg">
            <a asp-page="/Index" class="btn @(Model.Categoria == null ? "btn-primary" : "btn-ghost") btn-sm font-semibold text-base transition-all duration-300">
                <i class="fa-solid fa-border-all"></i> Todos
            </a>
            <a asp-page="/Index" asp-route-categoria="Smartphones" class="btn @(Model.Categoria == "Smartphones" ? "btn-primary" : "btn-ghost") btn-sm font-semibold text-base transition-all duration-300">
                <i class="fa-solid fa-mobile"></i> Smartphones
            </a>
            <a asp-page="/Index" asp-route-categoria="Audio" class="btn @(Model.Categoria == "Audio" ? "btn-primary" : "btn-ghost") btn-sm font-semibold text-base transition-all duration-300">
                <i class="fa-solid fa-headphones"></i> Audio
            </a>
            <a asp-page="/Index" asp-route-categoria="Laptops" class="btn @(Model.Categoria == "Laptops" ? "btn-primary" : "btn-ghost") btn-sm font-semibold text-base transition-all duration-300">
                <i class="fa-solid fa-laptop"></i> Laptops
            </a>
            <a asp-page="/Index" asp-route-categoria="Gaming" class="btn @(Model.Categoria == "Gaming" ? "btn-primary" : "btn-ghost") btn-sm font-semibold text-base transition-all duration-300">
                <i class="fa-solid fa-gamepad"></i> Gaming
            </a>
            <a asp-page="/Index" asp-route-categoria="Imagen" class="btn @(Model.Categoria == "Imagen" ? "btn-primary" : "btn-ghost") btn-sm font-semibold text-base transition-all duration-300">
                <i class="fa-solid fa-camera"></i> Imagen
            </a>
        </div>
    </div>

    <!-- Grid de productos -->
    @if (Model.Productos.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            @foreach (var producto in Model.Productos)
            {
                var esFavorito = Model.FavoritosMap.ContainsKey(producto.Id);
                var favoritoId = esFavorito ? Model.FavoritosMap[producto.Id] : 0;
                
                <div class="card bg-base-100 shadow-lg hover:shadow-2xl transition-all duration-300 border border-base-300 overflow-hidden group h-full flex flex-col">
                    <!-- Imagen del producto -->
                    <figure class="relative aspect-square bg-gradient-to-br from-base-200 to-base-300 overflow-hidden">
                        @if (!string.IsNullOrEmpty(producto.Imagen))
                        {
                            <img src="@producto.Imagen" alt="@producto.Nombre" 
                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/20 to-secondary/20">
                                <i class="fa-solid fa-box text-6xl text-primary/40"></i>
                            </div>
                        }
                        
                        <!-- Badge categoría -->
                        <span class="badge badge-primary badge-md absolute top-4 left-4 shadow-lg font-bold text-white">
                            @producto.Category
                        </span>
                        
                        <!-- Botón favorito -->
                        <form method="post" asp-page-handler="ToggleFavorito" class="absolute top-4 right-4">
                            <input type="hidden" name="productoId" value="@producto.Id" />
                            @if (esFavorito)
                            {
                                <input type="hidden" name="favoritoId" value="@favoritoId" />
                            }
                            <button type="submit" class="btn btn-circle btn-md shadow-lg bg-white border-2 border-base-300 hover:bg-error hover:border-error transition-all duration-200">
                                <i class="fa-@(esFavorito ? "solid" : "regular") fa-heart text-2xl @(esFavorito ? "text-error" : "text-error/40")"></i>
                            </button>
                        </form>
                    </figure>
                    
                    <div class="card-body p-5 flex-grow flex flex-col">
                        <!-- Nombre -->
                        <a asp-page="/Detalle" asp-route-id="@producto.Id" 
                           class="font-bold text-lg text-primary hover:text-secondary transition-colors line-clamp-2 min-h-14 leading-tight">
                            @producto.Nombre
                        </a>
                        
                        <!-- Descripción breve -->
                        <p class="text-sm text-base-content/70 line-clamp-2 mt-2 flex-grow">
                            Producto de calidad premium
                        </p>
                        
                        <!-- Precio y stock -->
                        <div class="flex items-center justify-between mt-4 pt-3 border-t border-base-200">
                            <span class="text-2xl font-bold text-primary">
                                @producto.Precio.ToString("C", new System.Globalization.CultureInfo("es-ES"))
                            </span>
                            @if (producto.Stock > 0)
                            {
                                <span class="badge badge-success badge-lg gap-1.5 font-semibold text-white">
                                    <i class="fa-solid fa-check text-sm"></i> Stock
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-error badge-lg font-semibold text-white">Agotado</span>
                            }
                        </div>
                        
                        <!-- Botón añadir al carrito -->
                        <form method="post" asp-page-handler="AddToCart" class="mt-5">
                            <input type="hidden" name="productoId" value="@producto.Id" />
                            <button type="submit" 
                                    class="btn btn-primary btn-md w-full font-bold text-lg transition-all duration-200 hover:shadow-lg" 
                                    @(producto.Stock <= 0 ? "disabled" : "")>
                                <i class="fa-solid fa-cart-plus text-lg"></i>
                                Añadir al carrito
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Estado vacío -->
        <div class="card bg-base-100 shadow-lg border-2 border-primary/20">
            <div class="card-body items-center text-center py-20 px-8">
                <div class="w-24 h-24 rounded-full bg-primary/10 flex items-center justify-center mb-6">
                    <i class="fa-solid fa-box-open text-5xl text-primary"></i>
                </div>
                <h2 class="text-3xl font-bold text-primary mb-3">No se encontraron productos</h2>
                <p class="text-lg text-base-content/70 max-w-md mb-6">
                    No hay productos que coincidan con tu búsqueda. Intenta con otros filtros o vuelve al catálogo completo.
                </p>
                <a asp-page="/Index" class="btn btn-primary btn-lg font-bold gap-2">
                    <i class="fa-solid fa-arrows-rotate text-lg"></i>
                    Ver todos los productos
                </a>
            </div>
        </div>
    }
</div>
