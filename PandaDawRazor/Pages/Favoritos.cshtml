@page
@model PandaDawRazor.Pages.FavoritosModel
@{
    ViewData["Title"] = "Mis Favoritos";
    Layout = "_Layout";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-10">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="w-8 h-0.5 bg-error rounded-full"></span>
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-error/50">Colección</p>
            </div>
            <h1 class="text-3xl font-extrabold text-base-content tracking-tight flex items-center gap-3">
                <i class="fa-solid fa-heart text-error/80"></i>
                Mis Favoritos
            </h1>
            <p class="text-base-content/40 mt-1.5 text-sm font-medium">
                @Model.Favoritos.Count @(Model.Favoritos.Count == 1 ? "producto guardado" : "productos guardados")
            </p>
        </div>
        <a asp-page="/Index" class="btn btn-ghost btn-sm rounded-2xl font-semibold text-xs text-base-content/45 gap-1.5">
            <i class="fa-solid fa-arrow-left text-[10px]"></i>
            Seguir comprando
        </a>
    </div>

    @if (!Model.Favoritos.Any())
    {
        <div class="card bg-white shadow-lg border-0 rounded-3xl">
            <div class="card-body items-center text-center py-20">
                <div class="w-24 h-24 rounded-3xl bg-gradient-to-br from-error/5 to-error/10 flex items-center justify-center mb-5">
                    <i class="fa-regular fa-heart text-4xl text-error/30"></i>
                </div>
                <h2 class="text-xl font-extrabold text-base-content tracking-tight">No tienes favoritos</h2>
                <p class="text-base-content/40 max-w-md text-sm mt-1 font-medium">
                    Guarda tus productos favoritos haciendo clic en el corazón para encontrarlos fácilmente.
                </p>
                <a asp-page="/Index" class="btn btn-primary mt-6 rounded-2xl font-bold gap-2">
                    <i class="fa-solid fa-bag-shopping text-sm"></i>
                    Explorar productos
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-7">
            @foreach (var favorito in Model.Favoritos)
            {
                <div class="card bg-white shadow-md hover:shadow-xl border-0 overflow-hidden group rounded-3xl">
                    <figure class="relative aspect-square bg-base-200/40 overflow-hidden card-img-overlay">
                        <a asp-page="/Detalle" asp-route-id="@favorito.ProductoId" class="w-full h-full">
                            @if (!string.IsNullOrEmpty(favorito.ProductoImagen))
                            {
                                <img src="@favorito.ProductoImagen" alt="@favorito.ProductoNombre" 
                                     class="w-full h-full object-cover img-zoom" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/4 to-secondary/4">
                                    <i class="fa-solid fa-box text-5xl text-primary/12"></i>
                                </div>
                            }
                        </a>
                        <form method="post" asp-page-handler="RemoveFavorito" asp-route-favoritoId="@favorito.Id" 
                              class="absolute top-3.5 right-3.5">
                            <button type="submit" class="btn btn-circle btn-sm shadow-lg bg-white/95 backdrop-blur-md border-0 hover:bg-error hover:text-white transition-all duration-300 hover:scale-110">
                                <i class="fa-solid fa-heart text-sm text-error"></i>
                            </button>
                        </form>
                        <span class="badge badge-primary badge-sm absolute top-3.5 left-3.5 shadow-lg font-bold text-[10px] uppercase tracking-wider rounded-xl px-3">@favorito.ProductoCategoria</span>
                    </figure>
                    <div class="card-body p-5">
                        <a asp-page="/Detalle" asp-route-id="@favorito.ProductoId" 
                           class="font-bold text-[15px] text-base-content hover:text-primary transition-colors duration-200 line-clamp-2 min-h-11 leading-snug">
                            @favorito.ProductoNombre
                        </a>
                        <div class="flex items-center justify-between mt-3 pt-3 border-t border-base-300/25">
                            <span class="text-xl font-extrabold text-primary tracking-tight">
                                @favorito.ProductoPrecio.ToString("C", new System.Globalization.CultureInfo("es-ES"))
                            </span>
                            <form method="post" asp-page-handler="AddToCart" asp-route-productoId="@favorito.ProductoId">
                                <button type="submit" class="btn btn-primary btn-sm rounded-2xl font-bold text-xs gap-1.5 shadow-md">
                                    <i class="fa-solid fa-cart-plus text-xs"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="card bg-white shadow-sm mt-8 rounded-2xl border-0">
            <div class="card-body py-4 flex-row items-center justify-between">
                <p class="text-base-content/35 text-xs font-medium flex items-center gap-1.5">
                    <i class="fa-solid fa-info-circle text-[10px]"></i>
                    Haz clic en el corazón para eliminar de favoritos
                </p>
                <a asp-page="/Index" class="btn btn-outline btn-sm rounded-2xl text-xs font-semibold gap-1.5">
                    <i class="fa-solid fa-plus text-[10px]"></i>
                    Añadir más
                </a>
            </div>
        </div>
    }
</div>
