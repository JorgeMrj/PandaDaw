@page
@model PandaDawRazor.Pages.CarritoModel
@{
    ViewData["Title"] = "Carrito";
    Layout = "_Layout";
}

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-10">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="w-8 h-0.5 bg-primary rounded-full"></span>
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary/60">Resumen</p>
            </div>
            <h1 class="text-3xl font-extrabold text-base-content tracking-tight flex items-center gap-3">
                <i class="fa-solid fa-bag-shopping text-primary/80"></i>
                Mi carrito
            </h1>
            @if (Model.Carrito?.TotalItems > 0)
            {
                <p class="text-base-content/40 mt-1.5 text-sm font-medium">@Model.Carrito.TotalItems productos en tu carrito</p>
            }
        </div>
        
        @if (Model.Carrito?.Lineas.Any() == true)
        {
            <form method="post" asp-page-handler="Vaciar">
                <button type="submit" class="btn btn-ghost btn-sm text-error/70 hover:text-error hover:bg-error/5 rounded-2xl font-semibold text-xs gap-1.5">
                    <i class="fa-solid fa-trash text-[10px]"></i>
                    Vaciar
                </button>
            </form>
        }
    </div>

    @if (Model.Carrito?.Lineas.Any() == true)
    {
        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Lista de productos -->
            <div class="flex flex-col gap-4 flex-1">
                @foreach (var linea in Model.Carrito.Lineas)
                {
                    <div class="card bg-white shadow-sm border-0 rounded-2xl hover:shadow-md">
                        <div class="card-body flex-row items-center gap-5 p-5">
                            <!-- Imagen -->
                            <div class="w-20 h-20 rounded-2xl bg-base-200/50 flex items-center justify-center shrink-0 overflow-hidden">
                                @if (!string.IsNullOrEmpty(linea.ProductoImagen))
                                {
                                    <img src="@linea.ProductoImagen" alt="@linea.ProductoNombre" class="w-full h-full object-cover rounded-2xl" />
                                }
                                else
                                {
                                    <i class="fa-solid fa-box text-2xl text-primary/20"></i>
                                }
                            </div>
                            
                            <!-- Info -->
                            <div class="flex flex-col gap-1 flex-1">
                                <a asp-page="/Detalle" asp-route-id="@linea.ProductoId" class="font-bold text-base-content hover:text-primary text-sm transition-colors">
                                    @linea.ProductoNombre
                                </a>
                                <p class="text-xs text-base-content/40 font-medium">@linea.PrecioUnitario.ToString("C") / unidad</p>
                                <p class="text-primary font-extrabold text-base mt-0.5">@linea.Subtotal.ToString("C")</p>
                            </div>
                            
                            <!-- Cantidad -->
                            <div class="flex items-center gap-1.5 bg-base-200/40 rounded-2xl px-1.5 py-1">
                                <form method="post" asp-page-handler="UpdateCantidad">
                                    <input type="hidden" name="productoId" value="@linea.ProductoId" />
                                    <input type="hidden" name="cantidad" value="@(linea.Cantidad - 1)" />
                                    <button type="submit" class="btn btn-ghost btn-xs btn-circle hover:bg-base-300/50" @(linea.Cantidad <= 1 ? "disabled" : "")>
                                        <i class="fa-solid fa-minus text-[10px]"></i>
                                    </button>
                                </form>
                                <span class="w-8 text-center font-bold text-sm">@linea.Cantidad</span>
                                <form method="post" asp-page-handler="UpdateCantidad">
                                    <input type="hidden" name="productoId" value="@linea.ProductoId" />
                                    <input type="hidden" name="cantidad" value="@(linea.Cantidad + 1)" />
                                    <button type="submit" class="btn btn-ghost btn-xs btn-circle hover:bg-base-300/50">
                                        <i class="fa-solid fa-plus text-[10px]"></i>
                                    </button>
                                </form>
                            </div>
                            
                            <!-- Eliminar -->
                            <form method="post" asp-page-handler="RemoveLinea">
                                <input type="hidden" name="productoId" value="@linea.ProductoId" />
                                <button type="submit" class="btn btn-ghost btn-sm btn-circle text-base-content/25 hover:text-error hover:bg-error/5 transition-colors">
                                    <i class="fa-solid fa-xmark text-sm"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <!-- Resumen -->
            <div class="lg:w-96">
                <div class="card bg-white shadow-lg border-0 sticky top-24 rounded-3xl">
                    <div class="card-body gap-5 p-7">
                        <h2 class="text-lg font-extrabold text-base-content tracking-tight">Resumen del pedido</h2>

                        <div class="flex flex-col gap-3">
                            @{
                                var subtotal = Model.Carrito.Total;
                                var iva = subtotal * 0.21m;
                                var total = subtotal + iva;
                            }
                            <div class="flex justify-between text-sm text-base-content/50 font-medium">
                                <span>Subtotal (@Model.Carrito.TotalItems items)</span>
                                <span>@subtotal.ToString("C", new System.Globalization.CultureInfo("es-ES"))</span>
                            </div>
                            <div class="flex justify-between text-sm text-base-content/50 font-medium">
                                <span>IVA (21%)</span>
                                <span>@iva.ToString("C", new System.Globalization.CultureInfo("es-ES"))</span>
                            </div>
                            <div class="h-px bg-base-300/30 my-1"></div>
                            <div class="flex justify-between font-extrabold text-lg">
                                <span>Total</span>
                                <span class="text-primary">@total.ToString("C", new System.Globalization.CultureInfo("es-ES"))</span>
                            </div>
                        </div>

                        <a asp-page="/Pago" class="btn btn-primary w-full mt-2 rounded-2xl font-bold h-12 text-sm">
                            <i class="fa-solid fa-lock mr-1.5 text-xs"></i>
                            Finalizar compra
                        </a>
                        <a asp-page="/Index" class="btn btn-ghost btn-sm w-full rounded-2xl text-xs font-semibold text-base-content/45">
                            <i class="fa-solid fa-arrow-left mr-1.5 text-[10px]"></i>
                            Seguir comprando
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Carrito vacío -->
        <div class="card bg-white shadow-lg border-0 rounded-3xl">
            <div class="card-body items-center text-center py-20">
                <div class="w-24 h-24 rounded-3xl bg-gradient-to-br from-primary/6 to-secondary/6 flex items-center justify-center mb-5">
                    <i class="fa-solid fa-bag-shopping text-4xl text-primary/30"></i>
                </div>
                <h2 class="text-xl font-extrabold text-base-content tracking-tight">Tu carrito está vacío</h2>
                <p class="text-base-content/40 max-w-md text-sm mt-1 font-medium">Añade productos para comenzar tu compra.</p>
                <a asp-page="/Index" class="btn btn-primary mt-6 rounded-2xl font-bold gap-2">
                    <i class="fa-solid fa-bag-shopping text-sm"></i>
                    Explorar productos
                </a>
            </div>
        </div>
    }
</div>