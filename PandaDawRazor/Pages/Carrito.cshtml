@page
@model PandaDawRazor.Pages.CarritoModel
@{
    ViewData["Title"] = "Carrito";
    Layout = "_Layout";
}

<div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Título -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-bold text-base-content flex items-center gap-3">
                <i class="fa-solid fa-shopping-cart text-primary"></i>
                Mi carrito
            </h1>
            @if (Model.Carrito?.TotalItems > 0)
            {
                <p class="text-base-content/60 mt-1">@Model.Carrito.TotalItems productos en tu carrito</p>
            }
        </div>
        
        @if (Model.Carrito?.Lineas.Any() == true)
        {
            <form method="post" asp-page-handler="Vaciar">
                <button type="submit" class="btn btn-ghost btn-sm text-error hover:bg-error/10">
                    <i class="fa-solid fa-trash mr-2"></i>
                    Vaciar carrito
                </button>
            </form>
        }
    </div>

    @if (Model.Carrito?.Lineas.Any() == true)
    {
        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Lista de productos -->
            <div class="flex flex-col gap-4 flex-1">
                @foreach (var linea in Model.Carrito.Lineas)
                {
                    <div class="card bg-base-100 shadow-md border border-base-300">
                        <div class="card-body flex-row items-center gap-4 p-4">
                            <!-- Imagen -->
                            <div class="w-16 h-16 rounded-lg bg-base-300 flex items-center justify-center shrink-0 overflow-hidden">
                                @if (!string.IsNullOrEmpty(linea.ProductoImagen))
                                {
                                    <img src="@linea.ProductoImagen" alt="@linea.ProductoNombre" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <i class="fa-solid fa-music text-2xl text-primary"></i>
                                }
                            </div>
                            
                            <!-- Info -->
                            <div class="flex flex-col gap-1 flex-1">
                                <a asp-page="/Detalle" asp-route-id="@linea.ProductoId" class="font-semibold text-base-content hover:text-primary">
                                    @linea.ProductoNombre
                                </a>
                                <p class="text-sm text-base-content/60">Precio unitario: @linea.PrecioUnitario.ToString("C")</p>
                                <p class="text-primary font-bold">Subtotal: @linea.Subtotal.ToString("C")</p>
                            </div>
                            
                            <!-- Controles de cantidad -->
                            <div class="flex items-center gap-2">
                                <form method="post" asp-page-handler="UpdateCantidad">
                                    <input type="hidden" name="productoId" value="@linea.ProductoId" />
                                    <input type="hidden" name="cantidad" value="@(linea.Cantidad - 1)" />
                                    <button type="submit" class="btn btn-ghost btn-xs btn-circle" @(linea.Cantidad <= 1 ? "disabled" : "")>
                                        <i class="fa-solid fa-minus text-xs"></i>
                                    </button>
                                </form>
                                
                                <span class="w-8 text-center font-medium">@linea.Cantidad</span>
                                
                                <form method="post" asp-page-handler="UpdateCantidad">
                                    <input type="hidden" name="productoId" value="@linea.ProductoId" />
                                    <input type="hidden" name="cantidad" value="@(linea.Cantidad + 1)" />
                                    <button type="submit" class="btn btn-ghost btn-xs btn-circle">
                                        <i class="fa-solid fa-plus text-xs"></i>
                                    </button>
                                </form>
                            </div>
                            
                            <!-- Eliminar -->
                            <form method="post" asp-page-handler="RemoveLinea">
                                <input type="hidden" name="productoId" value="@linea.ProductoId" />
                                <button type="submit" class="btn btn-ghost btn-sm text-error">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <!-- Resumen del pedido -->
            <div class="lg:w-96">
                <div class="card bg-base-100 shadow-md border border-base-300 sticky top-24">
                    <div class="card-body gap-4">
                        <h2 class="text-lg font-bold text-base-content">Resumen del pedido</h2>

                        <div class="flex flex-col gap-3">
                            @{
                                var subtotal = Model.Carrito.Total;
                                var iva = subtotal * 0.21m;
                                var total = subtotal + iva;
                            }
                            <div class="flex justify-between text-base-content/70">
                                <span>Subtotal (@Model.Carrito.TotalItems items)</span>
                                <span>@subtotal.ToString("C", new System.Globalization.CultureInfo("es-ES"))</span>
                            </div>
                            <div class="flex justify-between text-base-content/70">
                                <span>IVA (21%)</span>
                                <span>@iva.ToString("C", new System.Globalization.CultureInfo("es-ES"))</span>
                            </div>
                            <div class="divider my-0"></div>
                            <div class="flex justify-between font-bold text-lg">
                                <span>Total</span>
                                <span class="text-primary">@total.ToString("C", new System.Globalization.CultureInfo("es-ES"))</span>
                            </div>
                        </div>

                        <a asp-page="/Pago" class="btn btn-primary w-full mt-2">
                            <i class="fa-solid fa-lock mr-2"></i>
                            Finalizar compra
                        </a>
                        <a asp-page="/Index" class="btn btn-ghost btn-sm w-full">
                            <i class="fa-solid fa-arrow-left mr-2"></i>
                            Seguir comprando
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Carrito vacío -->
        <div class="card bg-base-100 shadow-md border border-base-300">
            <div class="card-body items-center text-center py-16">
                <div class="w-20 h-20 rounded-full bg-base-200 flex items-center justify-center mb-4">
                    <i class="fa-solid fa-cart-shopping text-4xl text-base-content/30"></i>
                </div>
                <h2 class="text-xl font-bold text-base-content">Tu carrito está vacío</h2>
                <p class="text-base-content/60 max-w-md">Añade productos para comenzar tu compra.</p>
                <a asp-page="/Index" class="btn btn-primary mt-4">
                    <i class="fa-solid fa-shopping-bag mr-2"></i>
                    Explorar productos
                </a>
            </div>
        </div>
    }
</div>